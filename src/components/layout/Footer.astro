---
/**
 * Footer — Navigationslinks, Rechtliches, Copyright
 */
import type { Locale } from "../../lib/i18n";
import { useTranslations } from "../../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const base = locale === "en" ? "/en" : "";

const imprintHref = `${base}/${locale === "en" ? "contact" : "kontakt"}`;

const legalLinks = [
  { href: `${base}/${locale === "en" ? "media" : "medien"}`, label: t("nav.media") },
  { href: `${base}/${locale === "en" ? "archive" : "archiv"}`, label: t("nav.archive") },
  { href: `${base}/${locale === "en" ? "privacy" : "datenschutz"}`, label: t("nav.privacy") },
  { href: `${base}/${locale === "en" ? "accessibility" : "barrierefreiheit"}`, label: t("nav.accessibility") },
];


const ticketHref = `${base}/${locale === "en" ? "registration" : "anmeldung"}`;

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container site-footer__inner">
    <!-- Spalte: Brand -->
    <div class="site-footer__brand">
      <img src="/images/TRK_26_Logo_negativ.svg" alt="Tierrechtskongress 2026" class="site-footer__trk-logo" />
    </div>

    <!-- Spalte: Ticket -->
    <div class="site-footer__ticket-col">
      <a href={ticketHref} class="site-footer__ticket-btn">
        <span class="btn-icon" style="--icon-url: url('/images/Ticket.svg'); width: 36px; height: 36px; background-color: #26282a;" aria-hidden="true"></span>
        {t("nav.registration")}
      </a>
    </div>

    <!-- Spalte: TIF + Credit -->
    <div class="site-footer__meta">
      <a href="https://www.tierimfokus.ch" target="_blank" rel="noopener noreferrer">
        <img src="/images/tif-logo-white.png" alt="Tier im Fokus (TIF)" class="site-footer__meta-tif-logo" />
      </a>
      <p class="site-footer__address">
        Tier im Fokus (TIF)<br />
        <a href="mailto:info@tierimfokus.ch" class="site-footer__address-link">info@tierimfokus.ch</a>
      </p>
      <div class="site-footer__social">
        <a href="https://www.instagram.com/tierimfokus" target="_blank" rel="noopener noreferrer" class="site-footer__social-link" aria-label="Instagram @tierimfokus">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://www.facebook.com/tierimfokus" target="_blank" rel="noopener noreferrer" class="site-footer__social-link" aria-label="Facebook @tierimfokus">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.youtube.com/tierimfokus" target="_blank" rel="noopener noreferrer" class="site-footer__social-link" aria-label="YouTube Tier im Fokus (TIF)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/tierimfokus" target="_blank" rel="noopener noreferrer" class="site-footer__social-link" aria-label="LinkedIn Tier im Fokus (TIF)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
      <p class="site-footer__credit">Layout &amp; Design:<br />Jessica Ladanie</p>
    </div>
  </div>

  <!-- Rechtliches -->
  <div class="site-footer__legal">
    <div class="container site-footer__legal-inner">
      <p class="site-footer__copyright">
        &copy; {year} {t("footer.copyright")}
      </p>
      <nav aria-label={locale === "de" ? "Rechtliche Links" : "Legal links"}>
        <ul role="list" class="site-footer__legal-list">
          {legalLinks.map(link => (
            <li><a href={link.href} class="site-footer__legal-link">{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--brand-black);
  color: var(--color-neutral-300);
  margin-top: auto;
}

.site-footer__inner {
  display: grid;
  grid-template-columns: auto 1fr;
  grid-template-rows: auto auto;
  gap: var(--space-4) var(--space-5);
  padding-top: var(--space-8);
  padding-bottom: var(--space-6);
}

.site-footer__ticket-col {
  grid-column: 1 / -1;
  display: none !important;
}

@media (min-width: 640px) {
  .site-footer__ticket-col {
    display: flex !important;
  }
}

.site-footer__brand {
  grid-column: 1;
  grid-row: 2;
}

.site-footer__meta {
  grid-column: 2;
  grid-row: 2;
  align-self: center;
}

@media (min-width: 640px) {
  .site-footer__inner {
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto;
    gap: var(--space-8);
    align-items: center;
    justify-items: center;
  }

  .site-footer__ticket-col {
    grid-column: unset;
    grid-row: unset;
  }

  .site-footer__brand,
  .site-footer__meta {
    grid-column: unset;
    grid-row: unset;
  }
}

/* Brand */
.site-footer__logo-link {
  display: inline-block;
  margin-bottom: var(--space-4);
}

.site-footer__logo {
  height: 40px;
  width: auto;
}

.site-footer__trk-logo {
  height: 170px;
  width: auto;
  margin-top: var(--space-6);
}

@media (min-width: 640px) {
  .site-footer__trk-logo {
    height: 220px;
  }
}

.site-footer__meta-tif-logo {
  height: 40px;
  width: auto;
  display: block;
  object-fit: contain;
}

.site-footer__ticket-col {
  display: flex;
  align-items: flex-start;
}

.site-footer__ticket-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0.7em 2em;
  background-image: url('/images/btn-v2-yellow.svg');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  border: none;
  font-family: var(--brand-font-bold);
  font-size: var(--text-xl);
  font-weight: var(--weight-semibold);
  color: #26282a;
  text-decoration: none;
  width: fit-content;
}

.site-footer__ticket-btn:hover {
  background-image: url('/images/btn-v2-beige.svg');
  color: #26282a;
}

.site-footer__ticket-btn:hover .btn-icon {
  background-color: #26282a;
}

/* Nav — 3 Zeilen à ~3 Links */
.site-footer__nav-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  list-style: none;
}

.site-footer__nav-link {
  font-size: var(--text-xs);
  color: var(--color-neutral-400);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.site-footer__nav-link:hover {
  color: #fff;
}

.site-footer__nav-link:focus-visible {
  outline-color: var(--color-primary-light);
}

/* Meta: Impressum + Credit */
.site-footer__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-4);
  text-align: right;
}

.site-footer__imprint-link {
  font-size: var(--text-sm);
  color: var(--color-neutral-400);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.site-footer__imprint-link:hover {
  color: #fff;
}

.site-footer__address {
  font-size: var(--text-xs);
  color: var(--color-neutral-500);
  max-width: none;
  margin: 0;
  line-height: var(--leading-relaxed);
}

.site-footer__address-link {
  color: var(--color-neutral-500);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.site-footer__address-link:hover {
  color: var(--color-neutral-300);
}

.site-footer__credit {
  font-size: var(--text-xs);
  color: var(--color-neutral-500);
  max-width: none;
  margin: 0;
  line-height: var(--leading-snug);
}

.site-footer__social {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-4);
}

.site-footer__social-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--color-neutral-300);
  text-decoration: none;
  transition: color 0.2s;
}

.site-footer__social-link:hover {
  color: #e5b969;
}

/* Legal */
.site-footer__legal {
  border-top: 1px solid var(--color-neutral-800);
  padding-block: var(--space-4);
}

.site-footer__legal-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}

.site-footer__copyright {
  font-size: var(--text-xs);
  color: var(--color-neutral-500);
  max-width: none;
}

.site-footer__legal-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  list-style: none;
}

.site-footer__legal-link {
  font-size: var(--text-xs);
  color: var(--color-neutral-500);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.site-footer__legal-link:hover {
  color: var(--color-neutral-300);
}
</style>
