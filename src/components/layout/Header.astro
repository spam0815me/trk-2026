---
/**
 * Header — Hauptnavigation mit Mobile-Menu und Sprachumschalter
 */
import type { Locale } from "../../lib/i18n";
import { useTranslations, localizeUrl } from "../../lib/i18n";

interface Props {
  locale: Locale;
  currentPath: string;
  alternateUrl: string;
}

const { locale, currentPath, alternateUrl } = Astro.props;
const t = useTranslations(locale);

const navItems = [
  { href: localizeUrl(locale, locale === "en" ? "/en/program" : "/programm"),       label: t("nav.program") },
  { href: localizeUrl(locale, locale === "en" ? "/en/speakers" : "/referentinnen"), label: t("nav.speakers") },
  { href: localizeUrl(locale, locale === "en" ? "/en/venue" : "/ort"),              label: t("nav.venue") },
  { href: localizeUrl(locale, locale === "en" ? "/en/contact" : "/kontakt"),        label: t("nav.contact") },
];

const registerHref = localizeUrl(locale, locale === "en" ? "/en/registration" : "/anmeldung");
const homeHref = locale === "en" ? "/en/" : "/";
---

<header class="site-header" role="banner">
  <div class="container site-header__inner">
    <!-- Logo / Seitenname -->
    <a href={homeHref} class="site-header__logo" aria-label={t("site.name") + " — " + (locale === "de" ? "Startseite" : "Home")}>
      <span class="site-header__logo-text">{t("site.name")}</span>
    </a>

    <!-- Desktop-Navigation -->
    <nav class="site-nav" aria-label={locale === "de" ? "Hauptnavigation" : "Main navigation"} id="main-nav">
      <ul class="site-nav__list" role="list">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={["site-nav__link", { "site-nav__link--active": currentPath === item.href }]}
              aria-current={currentPath === item.href ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Aktionen: CTA -->
    <div class="site-header__actions">
      <a href={registerHref} class="btn btn--primary site-header__cta">
        <span class="btn-icon" style="--icon-url: url('/images/Ticket.svg'); width: 32px; height: 32px;" aria-hidden="true"></span>
        {t("nav.registration")}
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      class="site-header__menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t("nav.openMenu")}
      id="menu-toggle"
      type="button"
    >
      <span class="site-header__menu-icon" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label={locale === "de" ? "Mobile Navigation" : "Mobile navigation"}>
      <ul class="mobile-menu__list" role="list">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={["mobile-menu__link", { "mobile-menu__link--active": currentPath === item.href }]}
              aria-current={currentPath === item.href ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="mobile-menu__cta">
          <a href={registerHref} class="btn btn--primary">
            <span class="btn-icon" style="--icon-url: url('/images/Ticket.svg'); width: 32px; height: 32px;" aria-hidden="true"></span>
            {t("nav.registration")}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu   = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    toggle.setAttribute(
      "aria-label",
      expanded
        ? (toggle.dataset.open ?? "Menü öffnen")
        : (toggle.dataset.close ?? "Menü schließen")
    );
    if (expanded) {
      menu?.setAttribute("hidden", "");
    } else {
      menu?.removeAttribute("hidden");
    }
  });

  // Schließen bei Klick auf Link
  menu?.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      menu.setAttribute("hidden", "");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>

<style>
/* ─── Header (TIF CI) ───────────────────────────────────────────────────────
   Weißer Hintergrund, 95px Höhe, dezenter Schatten — exakt wie tierimfokus.ch
   ─────────────────────────────────────────────────────────────────────────── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250, 250, 255, 0.75);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: none;
}

.site-header__inner {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  height: var(--height-header); /* 95px */
}

/* Logo */
.site-header__logo {
  text-decoration: none;
  flex-shrink: 0;
}

.site-header__logo-text {
  font-family: var(--brand-font-bold);
  font-weight: var(--weight-bold);
  font-size: var(--text-lg);
  color: var(--brand-black);
}

/* Desktop Nav */
.site-nav {
  display: none;
  flex: 1;
}

@media (min-width: 1024px) {
  .site-nav {
    display: block;
  }
}

.site-nav__list {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  list-style: none;
}

.site-nav__link {
  display: block;
  padding: var(--space-2) var(--space-3);
  font-family: var(--brand-font-bold);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--brand-black);
  text-decoration: none;
  border-radius: var(--border-radius-small);
  transition: color var(--transition-1), background-color var(--transition-1);
  white-space: nowrap;
}

.site-nav__link:hover,
.site-nav__link--active {
  color: var(--brand-green);
}

/* Aktionen */
.site-header__actions {
  display: none;
  align-items: center;
  gap: var(--space-4);
  margin-left: auto;
  flex-shrink: 0;
}

@media (min-width: 1024px) {
  .site-header__actions {
    display: flex;
  }
}

/* Mobile Menu Button */
.site-header__menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background-image: url('/images/yellow-05.png');
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  border: none;
  margin-left: auto;
  flex-shrink: 0;
  cursor: pointer;
}

@media (min-width: 1024px) {
  .site-header__menu-btn {
    display: none;
  }
}

.site-header__menu-icon {
  display: flex;
  flex-direction: column;
  gap: 5px;
  width: 22px;
}

.site-header__menu-icon span {
  display: block;
  height: 2px;
  background: var(--brand-black);
  border-radius: 2px;
  transition: transform var(--transition-1), opacity var(--transition-1);
}


/* Mobile Menu */
.mobile-menu {
  border-top: 1px solid var(--brand-platinum);
  background: var(--brand-white);
  padding: var(--space-4);
}

.mobile-menu__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.mobile-menu__link {
  display: block;
  padding: var(--space-3) var(--space-4);
  font-family: var(--brand-font-bold);
  font-size: var(--text-base);
  font-weight: var(--weight-medium);
  color: var(--brand-black);
  text-decoration: none;
  border-radius: var(--border-radius-small);
  transition: background-color var(--transition-1), color var(--transition-1);
}

.mobile-menu__link:hover,
.mobile-menu__link--active {
  background-color: #e3e3dd;
  color: var(--brand-black);
}

.mobile-menu__cta {
  margin-top: var(--space-4);
}

.mobile-menu__cta .btn {
  width: 100%;
  justify-content: center;
}

</style>
