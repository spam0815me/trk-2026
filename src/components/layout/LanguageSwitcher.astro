---
/**
 * Sprachumschalter DE / EN
 * Zeigt aktuell aktive Sprache und Link zur anderen Sprache.
 */
import type { Locale } from "../../lib/i18n";

interface Props {
  locale: Locale;
  /** URL der aktuellen Seite in der anderen Sprache */
  alternateUrl: string;
}

const { locale, alternateUrl } = Astro.props;
const targetLocale = locale === "de" ? "en" : "de";
const label = locale === "de" ? "English" : "Deutsch";
const ariaLabel = locale === "de"
  ? "Diese Seite auf Englisch anzeigen"
  : "View this page in German";
---

<div class="lang-switcher" role="navigation" aria-label={locale === "de" ? "Sprachauswahl" : "Language selection"}>
  <span class="lang-switcher__current" aria-current="true">
    <img
      src={locale === "de" ? "/images/Sprache_de.svg" : "/images/Sprache_eng.svg"}
      alt={locale.toUpperCase()}
      width="48" height="48"
    />
  </span>
  <span class="lang-switcher__sep" aria-hidden="true">/</span>
  <a
    href={alternateUrl}
    class="lang-switcher__link"
    lang={targetLocale}
    hreflang={targetLocale}
    aria-label={ariaLabel}
  >
    <img
      src={targetLocale === "de" ? "/images/Sprache_de.svg" : "/images/Sprache_eng.svg"}
      alt={label}
      width="48" height="48"
    />
  </a>
</div>

<style>
.lang-switcher {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
}

.lang-switcher__icon {
  flex-shrink: 0;
  margin-right: 0.15rem;
}

.lang-switcher__current {
  color: var(--color-text-muted);
  letter-spacing: 0.05em;
}

.lang-switcher__sep {
  color: var(--color-border-strong);
}

.lang-switcher__link {
  color: var(--color-primary);
  text-decoration: none;
  letter-spacing: 0.05em;
  padding: 0.2em 0.4em;
  border-radius: var(--radius-sm);
  transition: background-color var(--transition-fast);
}

.lang-switcher__link:hover {
  background-color: var(--color-primary-subtle);
  text-decoration: none;
}

.lang-switcher__link:focus-visible {
  outline: 2px solid var(--color-focus);
  outline-offset: 2px;
}
</style>
