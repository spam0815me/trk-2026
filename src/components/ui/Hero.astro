---
interface Props {
  title?: string;
  subtitle?: string;
  lead?: string;
  /** Visuell verstecktes Seiten-h1 (Dokumentstruktur/Screenreader). */
  heading?: string;
  ctaPrimary?: { href: string; label: string };
  ctaSecondary?: { href: string; label: string };
  size?: "default" | "large";
  pushDown?: boolean;
}

const { lead, heading, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="hero" aria-label="Hero">

  {heading && <h1 class="sr-only">{heading}</h1>}

  <!-- Parallax-Hintergrund -->
  <div class="hero__bg" id="hero-bg" aria-hidden="true"></div>

  <div class="hero__inner">

    <!-- Linke Spalte: Kuh -->
    <div class="hero__visual">
      <img src="/images/trk-logo.svg" alt="" class="hero__kuh" id="hero-kuh" aria-hidden="true" />
    </div>

    <!-- Rechte Spalte: Text + TIF-Logo -->
    <div class="hero__content">
      {lead && <p class="hero__lead" set:html={lead} />}

      <p class="hero__event-info">
        <span>23.–25. Oktober 2026</span>
        <img src="/images/x-separator.svg" alt="" class="hero__event-sep" aria-hidden="true" />
        <span>Photobastei Zürich</span>
      </p>

      {(ctaPrimary || ctaSecondary) && (
        <div class="hero__actions">
          {ctaPrimary && (
            <a href={ctaPrimary.href} class="hero__ticket-btn">
              <span class="btn-icon" style="--icon-url: url('/images/Ticket.svg'); width: 36px; height: 36px; background-color: #26282a;" aria-hidden="true"></span>
              {ctaPrimary.label}
            </a>
          )}
          {ctaSecondary && (
            <a href={ctaSecondary.href} class="btn btn--lg btn--organic-v2">
              {ctaSecondary.label}
            </a>
          )}
        </div>
      )}

      <a href="https://www.tierimfokus.ch" target="_blank" rel="noopener noreferrer" class="hero__organizer">
        <img src="/images/tif-logo-dark.png" alt="Tier im Fokus (TIF)" class="hero__organizer-logo hero__organizer-logo--hidden-mobile" />
      </a>
    </div>

  </div>
</section>

<script>
  const bg  = document.getElementById("hero-bg");
  const kuh = document.getElementById("hero-kuh");

  function onScroll() {
    const y = window.scrollY;
    // Hintergrund langsamer scrollen (0.3× Scrollgeschwindigkeit)
    if (bg)  bg.style.transform  = `translateY(${y * 0.3}px)`;
    // Kuh etwas schneller (0.15×) — subtiler Tiefeneffekt
    if (kuh) kuh.style.transform = `translateY(${y * 0.15}px)`;
  }

  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
.hero {
  position: relative;
  overflow: hidden;
  min-height: 85vh;
  display: flex;
  align-items: center;
}

/* Parallax-Hintergrund */
.hero__bg {
  position: absolute;
  inset: -20% 0;          /* Extra-Höhe damit beim Scrollen kein Rand sichtbar */
  background-image: url('/images/trk-header-bg.webp');
  background-size: cover;
  background-position: center top;
  will-change: transform;
  z-index: 0;
}

/* Layout */
.hero__inner {
  width: 100%;
  max-width: var(--max-width-xl, 1280px);
  margin-inline: auto;
  padding-inline: var(--space-12);
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: var(--space-8);
  position: relative;
  z-index: 1;
}

/* Linke Spalte */
.hero__visual {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-4);
}

.hero__organizer-logo {
  height: 42px;
  width: auto;
}

.hero__kuh {
  width: 100%;
  max-width: 680px;
  height: auto;
  display: block;
  will-change: transform;
}

/* Rechte Spalte */
.hero__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-6);
  padding-block: var(--space-16);
}

.hero__lead {
  font-size: var(--text-xl);
  color: #26282a;
  /* 44ch als Lesespalte auf Desktop, aber nie breiter als der Container –
     sonst ragt der zentrierte Block auf Mobile aus dem Viewport und wird
     durch overflow:hidden des Heros seitlich abgeschnitten. */
  max-width: min(44ch, 100%);
  line-height: var(--leading-relaxed);
  margin: 0;
}

.hero__event-info {
  font-family: 'Cubano', sans-serif;
  font-size: clamp(var(--text-lg), 4vw, var(--text-2xl));
  color: #26282a;
  margin: 0;
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: var(--space-2);
  white-space: nowrap;
}

.hero__event-tag {
  height: 1.4em;
  width: auto;
  display: inline-block;
  vertical-align: middle;
}

.hero__event-sep {
  height: 1.2em;
  width: auto;
  display: inline-block;
  vertical-align: middle;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  align-items: center;
  justify-content: center;
}

@media (min-width: 768px) {
  .hero__actions {
    justify-content: flex-start;
  }
}

.hero__ticket-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0.7em 2em;
  background-image: url('/images/btn-v2-yellow.svg');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  border: none;
  font-family: var(--brand-font-bold);
  font-size: var(--text-xl);
  font-weight: var(--weight-semibold);
  color: #26282a;
  text-decoration: none;
  width: fit-content;
  margin: 0 auto;
}

@media (min-width: 768px) {
  .hero__ticket-btn {
    margin: 0;
  }
}

.hero__ticket-btn:hover {
  background-image: url('/images/btn-v2-beige.svg');
}

.hero__organizer-logo--hidden-mobile {
  display: none;
}

@media (min-width: 768px) {
  .hero__organizer-logo--hidden-mobile {
    display: block;
  }
}

/* ─── Mobile-Layout (desktop-first: nach allen Basis-Regeln) ───────────────── */
@media (max-width: 768px) {
  .hero__inner {
    /* minmax(0, …) statt 1fr: verhindert, dass breite Kinder (z. B. der
       nowrap-Ticket-Button) die Spalte über den Viewport hinaus aufblähen
       und so den zentrierten Text seitlich abschneiden. */
    grid-template-columns: minmax(0, 1fr);
    padding-inline: var(--space-4);
    gap: var(--space-2);
    align-items: start;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__kuh {
    width: 90%;
    max-width: 380px;
    margin-top: var(--space-10);
  }

  .hero__content {
    align-items: center;
    text-align: center;
    padding-block: 0 var(--space-10);
    gap: var(--space-3);
    width: 100%;
    margin-top: calc(-1 * var(--space-6));
  }

  .hero__actions {
    width: 100%;
    justify-content: center;
  }

  .hero__lead {
    font-size: var(--text-lg);
  }
}

@media (max-width: 768px) {
  .hero__event-info {
    font-size: var(--text-xl);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    text-align: center;
  }

  .hero__event-sep {
    display: none;
  }

  .hero__content {
    gap: var(--space-2);
  }

  .hero__ticket-btn {
    font-size: var(--text-xl);
    padding: 0.8em 1.5em;
    max-width: 100%;
    white-space: nowrap;
  }
}

</style>
