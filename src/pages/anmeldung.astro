---
import PageLayout from "../layouts/PageLayout.astro";
import { useTranslations } from "../lib/i18n";

const locale = "de";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
---

<PageLayout
  title={t("registration.title")}
  description={t("registration.lead")}
  locale={locale}
  canonicalUrl={`${site}anmeldung/`}
  alternates={{ de: `${site}anmeldung/`, en: `${site}en/registration/` }}
  breadcrumbs={[{ label: t("registration.title") }]}
>
  <div class="section">
    <header class="section__header container--narrow">
      <h1 class="section__title">{t("registration.title")}</h1>
      <p class="section__lead">{t("registration.lead")}</p>
    </header>

    <!-- Preisübersicht -->
    <div class="container--narrow">
      <p class="ticket-note">Reduziert für Personen in finanziell schwierigen Verhältnissen. Soli unterstützt die Teilnahme anderer.</p>
    </div>
    <div class="container">
      <div class="ticket-grid">

        <a class="ticket-card ticket-card--featured btn-payrexx btn-payrexx-modal" href="https://tierimfokus.payrexx.com/pay?tid=4839d51d">
          <img src="/images/tickets/Eintritt_3-Tages.png" alt="3-Tagespass" class="ticket-card__img" />
          <div class="ticket-card__body">
            <h2 class="ticket-card__title">3-Tagespass</h2>
            <p class="ticket-card__dates">Freitag, Samstag &amp; Sonntag</p>
            <ul class="ticket-card__prices">
              <li><span>Reduziert</span><strong>CHF 100</strong></li>
              <li><span>Normal</span><strong>CHF 150</strong></li>
              <li><span>Soli</span><strong>CHF 200</strong></li>
            </ul>
          </div>
        </a>

        <a class="ticket-card btn-payrexx btn-payrexx-modal" href="https://tierimfokus.payrexx.com/pay?tid=4839d51d">
          <img src="/images/tickets/Eintritt_Freitag.png" alt="Eintritt Freitag" class="ticket-card__img" />
          <div class="ticket-card__body">
            <h2 class="ticket-card__title">1-Tagespass Freitag</h2>
            <p class="ticket-card__dates">23. Oktober</p>
            <ul class="ticket-card__prices">
              <li><span>Reduziert</span><strong>CHF 40</strong></li>
              <li><span>Normal</span><strong>CHF 55</strong></li>
              <li><span>Soli</span><strong>CHF 75</strong></li>
            </ul>
          </div>
        </a>

        <a class="ticket-card btn-payrexx btn-payrexx-modal" href="https://tierimfokus.payrexx.com/pay?tid=4839d51d">
          <img src="/images/tickets/Eintritt_Samstag.png" alt="Eintritt Samstag" class="ticket-card__img" />
          <div class="ticket-card__body">
            <h2 class="ticket-card__title">1-Tagespass Samstag</h2>
            <p class="ticket-card__dates">24. Oktober</p>
            <ul class="ticket-card__prices">
              <li><span>Reduziert</span><strong>CHF 55</strong></li>
              <li><span>Normal</span><strong>CHF 80</strong></li>
              <li><span>Soli</span><strong>CHF 100</strong></li>
            </ul>
          </div>
        </a>

        <a class="ticket-card btn-payrexx btn-payrexx-modal" href="https://tierimfokus.payrexx.com/pay?tid=4839d51d">
          <img src="/images/tickets/Eintritt_Sonntag.png" alt="Eintritt Sonntag" class="ticket-card__img" />
          <div class="ticket-card__body">
            <h2 class="ticket-card__title">1-Tagespass Sonntag</h2>
            <p class="ticket-card__dates">25. Oktober</p>
            <ul class="ticket-card__prices">
              <li><span>Reduziert</span><strong>CHF 40</strong></li>
              <li><span>Normal</span><strong>CHF 55</strong></li>
              <li><span>Soli</span><strong>CHF 75</strong></li>
            </ul>
          </div>
        </a>

      </div>
    </div>

    <!-- Payrexx Modal -->
    <div class="container--narrow">
      <div class="payrexx-cta">
        <a class="btn btn--organic-yellow btn--lg btn-payrexx btn-payrexx-modal" href="https://tierimfokus.payrexx.com/pay?tid=4839d51d" style="align-self: center;">
          <span class="btn-icon" style="--icon-url: url('/images/Ticket.svg'); width: 28px; height: 28px;" aria-hidden="true"></span>
          Ticket sichern!
        </a>
      </div>
    </div>
  </div>
</PageLayout>



<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js" integrity="sha512-bLT0Qm9VnAYZDflyKcBaQ2gg0hSYNQrJ8RilYldYQ1FxQYoCLtUjuuRuZo+fjqhx/qtq/1itJ0C2ejDxltZVFg==" crossorigin="anonymous"></script>
<script is:inline src="https://media.payrexx.com/modal/v1/modal.min.js"></script>
<script is:inline>
  jQuery(".btn-payrexx-modal").payrexxModal();
</script>

<style>
.ticket-note {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin-bottom: var(--space-6);
}

.ticket-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
  margin-bottom: var(--space-10);
}

@media (min-width: 480px) {
  .ticket-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 640px) {
  .ticket-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.ticket-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #f0f0ee;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.ticket-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(38,40,42,0.12);
}

.ticket-card--featured {
  background: #e3e3dd;
}

.ticket-card__img {
  width: 100%;
  aspect-ratio: 3 / 2;
  object-fit: cover;
  display: block;
}

.ticket-card__body {
  padding: var(--space-3);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  flex: 1;
}

@media (min-width: 640px) {
  .ticket-card__body {
    padding: var(--space-4) var(--space-5) var(--space-5);
  }
}

.ticket-card__title {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
  margin: 0;
}

@media (min-width: 640px) {
  .ticket-card__title {
    font-size: var(--text-base);
  }
}

.ticket-card__dates {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin: 0;
}

.ticket-card__prices {
  list-style: none;
  padding: 0;
  margin: var(--space-2) 0 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.ticket-card__title,
.ticket-card__dates {
  text-align: left;
}

.ticket-card__prices li {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: var(--text-xs);
  border-bottom: 1px solid rgba(38,40,42,0.08);
  padding-bottom: var(--space-1);
}

@media (min-width: 640px) {
  .ticket-card__prices li {
    font-size: var(--text-sm);
  }
}

.ticket-card__prices li:last-child {
  border-bottom: none;
}

.ticket-card__prices span {
  color: var(--color-text-muted);
}

.ticket-card__prices strong {
  color: var(--color-text);
  font-weight: var(--weight-semibold);
}

.payrexx-cta {
  margin-top: var(--space-8);
  margin-bottom: var(--space-10);
  display: flex;
  justify-content: center;
  text-align: center;
}
</style>
