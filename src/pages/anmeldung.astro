---
import PageLayout from "../layouts/PageLayout.astro";
import RegistrationForm from "../components/forms/RegistrationForm.astro";
import { useTranslations } from "../lib/i18n";

const locale = "de";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---

<PageLayout
  title={t("registration.title")}
  description={t("registration.lead")}
  locale={locale}
  canonicalUrl={`${site}anmeldung/`}
  alternates={{ de: `${site}anmeldung/`, en: `${site}en/registration/` }}
  breadcrumbs={[{ label: t("registration.title") }]}
>
  <div class="section">
    <header class="section__header container--narrow">
      <h1 class="section__title">{t("registration.title")}</h1>
      <p class="section__lead">{t("registration.lead")}</p>
    </header>

    <!-- Preisübersicht -->
    <div class="container--narrow">
      <div class="ticket-table-wrap">
        <h2 class="ticket-table__heading">Ticketpreise</h2>
        <p class="ticket-table__note">Reduziert gilt für Studierende, Rentner:innen und Personen in finanziell schwierigen Verhältnissen. Solidarität unterstützt die Teilnahme anderer.</p>
        <div class="ticket-table-scroll">
          <table class="ticket-table">
            <thead>
              <tr>
                <th scope="col"></th>
                <th scope="col">Reduziert</th>
                <th scope="col">Normal</th>
                <th scope="col">Solidarität</th>
              </tr>
            </thead>
            <tbody>
              <tr class="ticket-table__row--featured">
                <th scope="row">3-Tagespass<br><span>Freitag, Samstag &amp; Sonntag</span></th>
                <td>CHF 100</td>
                <td>CHF 150</td>
                <td>CHF 200</td>
              </tr>
              <tr>
                <th scope="row">1-Tagespass Freitag<br><span>23. Oktober</span></th>
                <td>CHF 40</td>
                <td>CHF 55</td>
                <td>CHF 75</td>
              </tr>
              <tr>
                <th scope="row">1-Tagespass Samstag<br><span>24. Oktober</span></th>
                <td>CHF 55</td>
                <td>CHF 80</td>
                <td>CHF 100</td>
              </tr>
              <tr>
                <th scope="row">1-Tagespass Sonntag<br><span>25. Oktober</span></th>
                <td>CHF 40</td>
                <td>CHF 55</td>
                <td>CHF 75</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <RegistrationForm locale={locale} />
    </div>
  </div>
</PageLayout>

<style>
.ticket-table-wrap {
  margin-bottom: var(--space-10);
}

.ticket-table__heading {
  font-size: var(--text-xl);
  margin-bottom: var(--space-2);
}

.ticket-table__note {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin-bottom: var(--space-5);
}

.ticket-table-scroll {
  overflow-x: auto;
}

.ticket-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.ticket-table thead tr {
  background: #26282a;
  color: #fafaff;
}

.ticket-table thead th {
  padding: var(--space-3) var(--space-5);
  text-align: left;
  font-weight: var(--weight-semibold);
  white-space: nowrap;
}

.ticket-table thead th:not(:first-child) {
  text-align: center;
}

.ticket-table tbody tr {
  border-bottom: 1px solid var(--color-border);
}

.ticket-table tbody tr:last-child {
  border-bottom: none;
}

.ticket-table tbody tr:hover {
  background: var(--color-bg-subtle);
}

.ticket-table__row--featured {
  background: #e3e3dd;
}

.ticket-table__row--featured:hover {
  background: #d8d8d2;
}

.ticket-table tbody th {
  padding: var(--space-4) var(--space-5);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
  text-align: left;
  white-space: nowrap;
}

.ticket-table tbody th span {
  display: block;
  font-size: var(--text-xs);
  font-weight: var(--weight-normal);
  color: var(--color-text-muted);
  margin-top: 2px;
}

.ticket-table tbody td {
  padding: var(--space-4) var(--space-5);
  text-align: center;
  font-weight: var(--weight-medium);
  color: #26282a;
}

.payrexx-wrap {
  margin-top: var(--space-8);
}

.payrexx-wrap iframe {
  border: none;
  background: transparent;
  display: block;
  transition: height 0.3s ease;
}
</style>
