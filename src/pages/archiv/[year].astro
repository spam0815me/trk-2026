---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const archive = await getCollection("archive");
  return archive.map(e => ({ params: { year: e.data.slug }, props: { edition: e } }));
}

const { edition } = Astro.props;
const locale = "de";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---

<PageLayout
  title={edition.data.title_de}
  description={edition.data.description_de}
  locale={locale}
  canonicalUrl={`${site}archiv/${edition.data.slug}/`}
  alternates={{
    de: `${site}archiv/${edition.data.slug}/`,
    en: `${site}en/archive/${edition.data.slug}/`,
  }}
  breadcrumbs={[
    { label: t("archive.title"), href: "/archiv" },
    { label: edition.data.title_de },
  ]}
>
  <article class="section">
    <header class="section__header">
      <h1 class="section__title">{edition.data.title_de}</h1>
      {edition.data.subtitle_de && <p class="archive-subtitle">{edition.data.subtitle_de}</p>}
      <p class="section__lead">{edition.data.description_de}</p>
    </header>

    <dl class="archive-detail__stats">
      <div>
        <dt>Datum</dt>
        <dd>{edition.data.date_de}</dd>
      </div>
      <div>
        <dt>Ort</dt>
        <dd>{edition.data.location}, {edition.data.city}</dd>
      </div>
      {edition.data.sessionsCount && (
        <div><dt>Sessions</dt><dd>{edition.data.sessionsCount}</dd></div>
      )}
      {edition.data.speakersCount && (
        <div><dt>Referierende</dt><dd>{edition.data.speakersCount}</dd></div>
      )}
      {edition.data.attendeesCount && (
        <div><dt>Teilnehmende</dt><dd>{edition.data.attendeesCount}</dd></div>
      )}
    </dl>

    {edition.data.highlights_de && edition.data.highlights_de.length > 0 && (
      <section class="archive-highlights">
        <h2>Highlights</h2>
        <ul class="archive-highlights__list">
          {edition.data.highlights_de.map((h: string) => <li>{h}</li>)}
        </ul>
      </section>
    )}

    <nav class="archive-back">
      <a href="/archiv" class="btn btn--ghost">← {t("archive.back")}</a>
    </nav>
  </article>
</PageLayout>

<style>
.archive-subtitle {
  font-size: var(--text-xl);
  color: var(--color-text-muted);
  font-style: italic;
  margin-bottom: var(--space-4);
  max-width: none;
}

.archive-detail__stats {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-8);
  margin-bottom: var(--space-10);
  padding: var(--space-6);
  background: var(--color-bg-subtle);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
}

.archive-detail__stats > div {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.archive-detail__stats dt {
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-muted);
}

.archive-detail__stats dd {
  font-weight: var(--weight-bold);
  font-size: var(--text-lg);
}

.archive-highlights {
  margin-bottom: var(--space-8);
}

.archive-highlights h2 {
  font-size: var(--text-xl);
  margin-bottom: var(--space-4);
}

.archive-highlights__list {
  padding-left: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.archive-back {
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-5);
}
</style>
