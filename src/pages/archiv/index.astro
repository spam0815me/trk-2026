---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";
import { getCollection } from "astro:content";

const locale = "de";
const t = useTranslations(locale);

const archiveRaw = await getCollection("archive");
const editions = archiveRaw
  .sort((a, b) => b.data.year - a.data.year);

const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---

<PageLayout
  title={t("archive.title")}
  description={t("archive.lead")}
  locale={locale}
  canonicalUrl={`${site}archiv/`}
  alternates={{ de: `${site}archiv/`, en: `${site}en/archive/` }}
  breadcrumbs={[{ label: t("archive.title") }]}
>
  <div class="section">
    <header class="section__header">
      <h1 class="section__title">{t("archive.title")}</h1>
      <p class="section__lead">{t("archive.lead")}</p>
    </header>

    <ul class="archive-list" role="list">
      {editions.map(edition => (
        <li class="archive-item">
          <article>
            <h2 class="archive-item__year">
              <a href={`/archiv/${edition.data.slug}`} class="archive-item__link">
                {edition.data.title_de}
              </a>
            </h2>
            <p class="archive-item__date">
              {edition.data.date_de} · {edition.data.city}
            </p>
            <p class="archive-item__desc">{edition.data.description_de}</p>
            <dl class="archive-item__stats">
              {edition.data.sessionsCount && (
                <div>
                  <dt>Sessions</dt>
                  <dd>{edition.data.sessionsCount}</dd>
                </div>
              )}
              {edition.data.speakersCount && (
                <div>
                  <dt>Referent:innen</dt>
                  <dd>{edition.data.speakersCount}</dd>
                </div>
              )}
              {edition.data.attendeesCount && (
                <div>
                  <dt>Teilnehmende</dt>
                  <dd>{edition.data.attendeesCount}</dd>
                </div>
              )}
            </dl>
            <a href={`/archiv/${edition.data.slug}`} class="btn btn--ghost btn--sm">
              {t("archive.viewEdition")} →
            </a>
          </article>
        </li>
      ))}
    </ul>
  </div>
</PageLayout>

<style>
.archive-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  list-style: none;
}

.archive-item article {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  transition: box-shadow var(--transition-fast);
}

.archive-item article:hover {
  box-shadow: var(--shadow-md);
}

.archive-item__year {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-2);
}

.archive-item__link {
  color: var(--color-text);
  text-decoration: none;
}
.archive-item__link:hover { color: var(--color-primary); }

.archive-item__date {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin-bottom: var(--space-3);
  max-width: none;
}

.archive-item__desc {
  margin-bottom: var(--space-4);
  color: var(--color-text-muted);
}

.archive-item__stats {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-6);
  margin-bottom: var(--space-4);
  font-size: var(--text-sm);
}

.archive-item__stats > div {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.archive-item__stats dt {
  font-weight: var(--weight-semibold);
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.archive-item__stats dd {
  font-weight: var(--weight-bold);
  font-size: var(--text-lg);
  color: var(--color-primary);
}
</style>
