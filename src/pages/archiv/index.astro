---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";

const locale = "de";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---

<PageLayout
  title={t("archive.title")}
  description={t("archive.lead")}
  locale={locale}
  canonicalUrl={`${site}archiv/`}
  alternates={{ de: `${site}archiv/`, en: `${site}en/archive/` }}
  breadcrumbs={[{ label: t("archive.title") }]}
>
  <div class="section">
    <header class="section__header">
      <h1 class="section__title">{t("archive.title")}</h1>
    </header>

    <div class="archive-edition">
      <div class="archive-edition__header">
        <img src="/images/TRK_2023_Logo.png" alt="Tierrechtskongress 2023" class="archive-edition__logo" />
        <div class="archive-edition__info">
          <h2 class="archive-edition__title">Tierrechtskongress 2023</h2>
          <p class="archive-edition__meta">Erster Kongress · Zürich</p>
          <p class="archive-edition__desc">Der erste Tierrechtskongress fand 2023 in Zürich statt. Hier findest du die Aufzeichnungen der Vorträge.</p>
        </div>
      </div>

      <div class="archive-playlist-wrap">
        <p class="archive-playlist__label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8"/><path d="M12 3v4"/><polygon points="10 11 16 14 10 17 10 11"/></svg>
          Playlist · alle Vorträge vom TRK 2023
        </p>
        <div class="archive-playlist">
          <iframe
            src="https://www.youtube.com/embed/videoseries?list=PLZ9_9DPeg0yNAM8lS3xBI-Itc-02Ny5TA"
            title="Tierrechtskongress 2023 – Playlist"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
        <a
          href="https://www.youtube.com/playlist?list=PLZ9_9DPeg0yNAM8lS3xBI-Itc-02Ny5TA"
          target="_blank"
          rel="noopener noreferrer"
          class="archive-yt-btn"
        >
          <img src="/images/youtube.svg" alt="" class="archive-yt-icon" aria-hidden="true" />
          YouTube
        </a>
      </div>
    </div>
  </div>
</PageLayout>

<style>
.archive-edition {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.archive-edition__header {
  display: flex;
  align-items: flex-start;
  gap: var(--space-8);
}

.archive-edition__logo {
  height: 120px;
  width: auto;
  flex-shrink: 0;
}

.archive-edition__title {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-2);
}

.archive-edition__meta {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  margin-bottom: var(--space-3);
  max-width: none;
}

.archive-edition__desc {
  max-width: 60ch;
}

.archive-playlist-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-2);
  max-width: 640px;
}

.archive-playlist__label {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text-muted);
  max-width: none;
}

.archive-playlist {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.archive-yt-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0.6em 2em;
  background-image: url('/images/btn-v1-black.svg');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  border: none;
  font-family: var(--brand-font-bold);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: #fafaff;
  text-decoration: none;
}

.archive-yt-icon {
  height: 20px;
  width: auto;
}

.archive-playlist iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
</style>
