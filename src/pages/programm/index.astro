---
/**
 * Programmübersicht — Deutsch
 */
import PageLayout from "../../layouts/PageLayout.astro";
import SessionCard from "../../components/program/SessionCard.astro";
import { useTranslations, getField } from "../../lib/i18n";
import { getCollection } from "astro:content";
import { getCurrentSessions, toSessionView, getUniqueDays } from "../../lib/sessions";

const locale = "de";
const t = useTranslations(locale);

const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
const canonicalUrl = `${site}programm/`;
const alternates = {
  de: canonicalUrl,
  en: `${site}en/program/`,
};

const sessions = await getCurrentSessions(2026);
const rooms    = await getCollection("rooms");
const speakers = await getCollection("speakers");

const days = getUniqueDays(sessions);

// Nur Räume anzeigen, die auch wirklich Sessions haben
const usedRoomIds = new Set(sessions.map(s => s.data.roomId));
const activeRooms = rooms
  .filter(r => usedRoomIds.has(r.data.id))
  .sort((a, b) => (a.data.sortOrder ?? 0) - (b.data.sortOrder ?? 0));

// Raum-Map
const roomMap = Object.fromEntries(rooms.map(r => [r.data.id, r]));
// Speaker-Map
const speakerMap = Object.fromEntries(speakers.map(s => [s.data.id, s]));

// Session-Daten aufbereiten
function formatDayFull(dateStr: string) {
  const d = new Date(dateStr + "T00:00:00");
  return d.toLocaleDateString("de-CH", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
}

const sessionViews = sessions.map(s => ({
  view: toSessionView(s, locale),
  roomName: getField<string>("name", locale, roomMap[s.data.roomId]?.data as unknown as Record<string, unknown> ?? {}),
  speakerNames: s.data.speakerIds.map(id => speakerMap[id]?.data.name ?? ""),
  speakerPhotos: s.data.speakerIds.map(id => speakerMap[id]?.data.photo ?? ""),
  speakerSlugs: s.data.speakerIds.map(id => speakerMap[id]?.data.slug ?? ""),
}));

// Timetable-Daten: pro Tag → Zeitslots → Räume
const roomIcons: Record<string, string> = {
  "saal-a": "/images/Raum_Sandra.svg",
  "saal-b": "/images/Raum_Yvonne.svg",
};

const activeRoomData = activeRooms.map(r => ({
  name:  getField<string>("name",  locale, r.data as unknown as Record<string, unknown> ?? {}),
  story: getField<string>("story", locale, r.data as unknown as Record<string, unknown> ?? {}),
  photo: r.data.photo,
  icon:  roomIcons[r.data.id],
}));

// Pausen & Rahmenprogramm pro Tag
const breaksByDay: Record<number, { time: string; label: string; icon: string }[]> = {
  1: [
    { time: "19:00", label: "zNacht", icon: "/images/Znacht.svg" },
    { time: "20:30", label: "Abendprogramm", icon: "/images/Fiesta.svg" },
  ],
  2: [
    { time: "12:30", label: "Mittagspause", icon: "/images/Mittag.svg" },
    { time: "16:00", label: "Kaffeepause", icon: "/images/Pause.svg" },
    { time: "18:30", label: "zNacht", icon: "/images/Znacht.svg" },
    { time: "20:00", label: "Abendprogramm", icon: "/images/Fiesta.svg" },
  ],
  3: [
    { time: "09:00", label: "Zmorge", icon: "/images/Zmorge.svg" },
    { time: "13:00", label: "Mittagspause", icon: "/images/Mittag.svg" },
  ],
};

const timetableData = days.map(day => {
  const daySessions = sessionViews.filter(sv => sv.view.day === day);
  const sessionTimes = [...new Set(daySessions.map(sv => sv.view.startTime))];
  const breakTimes = (breaksByDay[day] ?? []).map(b => b.time);
  const allTimes = [...new Set([...sessionTimes, ...breakTimes])].sort();

  return {
    day,
    date: daySessions[0]?.view.date ?? "",
    timeSlots: allTimes.map(time => {
      const breakEntry = (breaksByDay[day] ?? []).find(b => b.time === time);
      return {
        time,
        isBreak: !!breakEntry,
        breakLabel: breakEntry?.label ?? "",
        breakIcon: breakEntry?.icon ?? "",
        cells: activeRooms.map(room =>
          daySessions.find(sv => sv.view.startTime === time && sv.view.roomId === room.data.id) ?? null
        ),
      };
    }),
  };
});
---

<PageLayout
  title={t("program.title")}
  description={t("program.lead")}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  breadcrumbs={[{ label: t("program.title") }]}
  fullWidth
>
  <div class="container">
    <header class="section__header" style="padding-top: var(--space-8);">
      <h1 class="section__title">{t("program.title")}</h1>
      <p class="section__lead"><strong>Drei Tage, zwei Räume, viele Perspektiven.</strong> Pro Zeitslot laufen in Raum Sandra und Raum Yvonne gleichzeitig Vorträge — du wählst, was dich bewegt.</p>
    </header>


  </div>

  <!-- Sessions als Timetable (Zeitslots × Räume) -->
  <div class="container program-list" id="program-list">
    {timetableData.map(({ day, date, timeSlots }) => (
      <section class="program-day" data-day={day} aria-labelledby={`day-heading-${day}`}>
        <h2 class="program-day__heading" id={`day-heading-${day}`}>
          {formatDayFull(date)}
        </h2>

        <div class="timetable" style={`--room-count: ${activeRooms.length}`}>
          <!-- Raum-Header -->
          <div class="timetable__header">
            <div class="timetable__time-col"></div>
            {activeRoomData.map(room => (
              <div class="timetable__room-card">
                <div class="timetable__room-info">
                  {room.icon && <img src={room.icon} alt={room.name} class="timetable__room-icon" />}
                </div>
                {day === 1 && (
                  <div class="timetable__room-intro">
                    <strong class="timetable__room-name">{room.name}</strong>
                    {room.story && <p class="timetable__room-story">{room.story}</p>}
                  </div>
                )}
              </div>
            ))}
          </div>

          <!-- Zeitslot-Zeilen -->
          {timeSlots.map(({ time, isBreak, breakLabel, breakIcon, cells }) => (
            isBreak ? (
              <div class="timetable__break-row">
                <span class="timetable__break-time">{time}</span>
                <div class="timetable__break">
                  {breakIcon && <img src={breakIcon} alt={breakLabel} class="timetable__break-icon" />}
                </div>
              </div>
            ) : (
              <div class="timetable__row">
                <div class="timetable__time">{time}</div>
                {cells.map(sv => (
                  <div class="timetable__cell">
                    {sv ? (
                      <SessionCard
                        id={sv.view.id}
                        slug={sv.view.slug}
                        title={sv.view.title}
                        description={sv.view.description}
                        type={sv.view.type}
                        language={sv.view.language}
                        startTime={sv.view.startTime}
                        endTime={sv.view.endTime}
                        durationMinutes={sv.view.durationMinutes}
                        day={sv.view.day}
                        date={sv.view.date}
                        roomName={sv.roomName}
                        roomId={sv.view.roomId}
                        speakerNames={sv.speakerNames}
                        speakerPhotos={sv.speakerPhotos}
                        speakerSlugs={sv.speakerSlugs}
                        locale={locale}
                        registrationRequired={sv.view.registrationRequired}
                        recording={sv.view.recording}
                        status={sv.view.status}
                      />
                    ) : (
                      <div class="timetable__empty" aria-hidden="true"></div>
                    )}
                  </div>
                ))}
              </div>
            )
          ))}
        </div>
      </section>
    ))}

  </div>
</PageLayout>

<!-- Merkliste-Button (fix) -->
<a href="/programm/merkliste" class="merkliste-fab" id="merkliste-fab" aria-label="Merkliste öffnen">
  <span class="btn-icon" style="--icon-url: url('/images/x-separator.svg'); width: 18px; height: 18px;" aria-hidden="true"></span>
  <span class="merkliste-fab__label">Merkliste</span>
  <span class="merkliste-fab__count" id="merkliste-count" hidden>0</span>
</a>

<script src="../../scripts/bookmarks.js"></script>
<script>
  function updateMerklist() {
    const count = JSON.parse(localStorage.getItem("trk2026_bookmarks") ?? "[]").length;
    const badge = document.getElementById("merkliste-count");
    const fab   = document.getElementById("merkliste-fab");
    if (!badge || !fab) return;
    badge.textContent = String(count);
    badge.hidden = count === 0;
    fab.classList.toggle("merkliste-fab--has-items", count > 0);
  }
  updateMerklist();
  window.addEventListener("bookmarks-changed", updateMerklist);
  window.addEventListener("storage", updateMerklist);
</script>

<style>
/* Raum-Geschichten */
.room-stories {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 380px), 1fr));
  gap: var(--space-5);
  margin-bottom: var(--space-12);
}

.room-story {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-6);
  background: transparent;
}

.room-story__photo {
  width: 180px;
  height: 180px;
  object-fit: cover;
  object-position: center 20%;
  flex-shrink: 0;
  -webkit-mask-image: url('/images/yellow-05.png');
  mask-image: url('/images/yellow-05.png');
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

.room-story__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.room-story__icon {
  height: 48px;
  width: auto;
  display: block;
}

.room-story__name {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
  margin: 0;
}

.room-story__text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  max-width: none;
  margin: 0;
}

.timetable__room-intro {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  margin-top: var(--space-2);
}

.timetable__room-name {
  font-size: var(--text-base);
  font-weight: var(--weight-bold);
  color: var(--color-text);
}

.timetable__room-story {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  margin: 0;
  max-width: none;
}

/* Tag-Gruppen */
.program-day {
  margin-bottom: var(--space-10);
}

.program-day__heading {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-size: var(--text-2xl);
  margin-bottom: var(--space-5);
  padding-bottom: var(--space-3);
  border-bottom: 2px solid var(--color-primary);
}

.program-day__date {
  font-size: var(--text-lg);
  font-weight: var(--weight-normal);
  color: var(--color-text-muted);
}

/* Timetable — Mobile first */
.timetable {
  /* kein overflow-x auf mobile */
}

/* Raum-Header: auf Mobile ausblenden */
.timetable__header {
  display: none;
}

/* Zeitslot-Zeile: auf Mobile gestapelt */
.timetable__row {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.timetable__time {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-muted);
  padding-top: 0;
  text-align: left;
}

.timetable__cell {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.timetable__cell > :global(.session-card) {
  flex: 1;
}

.timetable__empty {
  display: none; /* Leerzellen auf Mobile verstecken */
}

/* Pausen — Mobile */
.timetable__break-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.timetable__break-time {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-muted);
  text-align: left;
  flex-shrink: 0;
  width: 48px;
}

.timetable__break {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e3e3dd;
  border-radius: var(--radius-md);
  padding: var(--space-3) var(--space-4);
}

.timetable__break-icon {
  height: 40px;
  width: auto;
}

/* Raum-Karten */
.timetable__room-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-3);
  padding-bottom: var(--space-4);
  margin-bottom: var(--space-4);
}

.timetable__room-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-3);
}

.timetable__room-icon {
  height: 56px;
  width: auto;
  display: block;
}

.timetable__room-name {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
}

.timetable__room-story {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  line-height: var(--leading-snug);
  max-width: none;
  margin: 0;
}

.timetable__time-col {
  /* Platzhalter für die Zeitspalte im Header */
}

/* Desktop: Grid-Layout */
@media (min-width: 640px) {
  .timetable {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .timetable__header {
    display: grid;
    grid-template-columns: 72px repeat(var(--room-count), 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-1);
    align-items: stretch;
    min-width: 480px;
  }

  .timetable__row {
    display: grid;
    flex-direction: unset;
    grid-template-columns: 72px repeat(var(--room-count), 1fr);
    gap: var(--space-3);
    align-items: stretch;
    min-width: 480px;
  }

  .timetable__time {
    padding-top: var(--space-3);
    text-align: right;
    padding-right: var(--space-2);
  }

  .timetable__empty {
    display: block;
    height: 100%;
    min-height: 60px;
    border: 1px dashed rgba(38,40,42,0.12);
    border-radius: var(--radius-lg);
  }

  .timetable__break-row {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-3);
    min-width: 480px;
    align-items: center;
  }

  .timetable__break-time {
    text-align: right;
    padding-right: var(--space-2);
    width: auto;
  }
}

/* Leer */
.program-empty {
  padding: var(--space-12);
  text-align: center;
  color: var(--color-text-muted);
}

/* Ausgeblendet durch Filter */
.program-day[data-hidden] {
  display: none;
}

/* Merkliste FAB */
.merkliste-fab {
  position: fixed;
  bottom: max(var(--space-6), env(safe-area-inset-bottom, var(--space-6)));
  right: max(var(--space-6), env(safe-area-inset-right, var(--space-6)));
  z-index: 100;
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: 0.6em 1.6em;
  background-image: url('/images/btn-v2-black.svg');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  font-family: var(--brand-font-bold);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: #fafaff;
  text-decoration: none;
  transition: opacity 0.2s;
}

.merkliste-fab .btn-icon {
  background-color: #fafaff;
}

.merkliste-fab:hover {
  background-image: url('/images/btn-v2-yellow.svg');
  color: #26282a;
}

.merkliste-fab:hover .btn-icon {
  background-color: #26282a;
}

.merkliste-fab--has-items {
  background-image: url('/images/btn-v2-yellow.svg');
  color: #26282a;
}

.merkliste-fab--has-items .btn-icon {
  background-color: #26282a;
}

.merkliste-fab__count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #26282a;
  color: #fafaff;
  border-radius: 999px;
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  width: 20px;
  height: 20px;
  line-height: 1;
}

.merkliste-fab--has-items .merkliste-fab__count {
  background: #26282a;
  color: #fafaff;
}
</style>
