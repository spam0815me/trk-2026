---
/**
 * Programmübersicht — Deutsch
 */
import PageLayout from "../../layouts/PageLayout.astro";
import SessionCard from "../../components/program/SessionCard.astro";
import { useTranslations, getField } from "../../lib/i18n";
import { getCollection } from "astro:content";
import { getCurrentSessions, toSessionView, getUniqueDays } from "../../lib/sessions";

const locale = "de";
const t = useTranslations(locale);

const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
const canonicalUrl = `${site}programm/`;
const alternates = {
  de: canonicalUrl,
  en: `${site}en/program/`,
};

const sessions = await getCurrentSessions(2026);
const rooms    = await getCollection("rooms");
const speakers = await getCollection("speakers");

const days = getUniqueDays(sessions);

// Nur Räume anzeigen, die auch wirklich Sessions haben
const usedRoomIds = new Set(sessions.map(s => s.data.roomId));
const activeRooms = rooms
  .filter(r => usedRoomIds.has(r.data.id))
  .sort((a, b) => (a.data.sortOrder ?? 0) - (b.data.sortOrder ?? 0));

// Raum-Map
const roomMap = Object.fromEntries(rooms.map(r => [r.data.id, r]));
// Speaker-Map
const speakerMap = Object.fromEntries(speakers.map(s => [s.data.id, s]));

// Session-Daten aufbereiten
function formatDayFull(dateStr: string) {
  const d = new Date(dateStr + "T00:00:00");
  return d.toLocaleDateString("de-CH", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
}

const sessionViews = sessions.map(s => ({
  view: toSessionView(s, locale),
  roomName: getField<string>("name", locale, roomMap[s.data.roomId]?.data as unknown as Record<string, unknown> ?? {}),
  speakerNames: s.data.speakerIds.map(id => speakerMap[id]?.data.name ?? ""),
  speakerPhotos: s.data.speakerIds.map(id => speakerMap[id]?.data.photo ?? ""),
  speakerSlugs: s.data.speakerIds.map(id => speakerMap[id]?.data.slug ?? ""),
}));

// Timetable-Daten: pro Tag → Zeitslots → Räume
const roomIcons: Record<string, string> = {
  "saal-a": "/images/Raum_Sandra.svg",
  "saal-b": "/images/Raum_Yvonne.svg",
};

const activeRoomData = activeRooms.map(r => ({
  name:  getField<string>("name",  locale, r.data as unknown as Record<string, unknown> ?? {}),
  story: getField<string>("story", locale, r.data as unknown as Record<string, unknown> ?? {}),
  photo: r.data.photo,
  icon:  roomIcons[r.data.id],
}));

// Pausen & Rahmenprogramm pro Tag (catering: Verpflegung von Spicy Roots; potluck: Mitbring-Buffet)
type DayBreak = { time: string; label: string; icon: string; catering?: boolean; potluck?: boolean };
const breaksByDay: Record<number, DayBreak[]> = {
  1: [
    { time: "19:00", label: "zNacht", icon: "/images/Znacht.svg", catering: true },
    { time: "20:30", label: "Abendprogramm", icon: "/images/Fiesta.svg" },
  ],
  2: [
    { time: "12:30", label: "Mittagspause", icon: "/images/Mittag.svg", catering: true },
    { time: "16:00", label: "Kaffeepause", icon: "/images/Pause.svg" },
    { time: "18:30", label: "zNacht", icon: "/images/Znacht.svg", catering: true },
    { time: "20:00", label: "Abendprogramm", icon: "/images/Fiesta.svg" },
  ],
  3: [
    { time: "09:00", label: "Zmorge", icon: "/images/Zmorge.svg", potluck: true },
    { time: "13:00", label: "Mittagspause", icon: "/images/Mittag.svg", catering: true },
  ],
};

// Uhrzeit um Minuten verschieben ("15:00", -60 -> "14:00")
function shiftTime(hhmm: string, deltaMin: number) {
  const [h, m] = hhmm.split(":").map(Number);
  const total = h * 60 + m + deltaMin;
  const hh = Math.floor(total / 60);
  const mm = total % 60;
  return `${String(hh).padStart(2, "0")}:${String(mm).padStart(2, "0")}`;
}

const timetableData = days.map(day => {
  const daySessions = sessionViews.filter(sv => sv.view.day === day);
  const sessionTimes = [...new Set(daySessions.map(sv => sv.view.startTime))];

  // Türöffnung (1 h vorher) + Begrüssung (30 min vorher) relativ zur ersten Session des Tages.
  // Türöffnung entfällt, wenn vor der ersten Session bereits Rahmenprogramm liegt
  // (z.B. Sonntag: gemeinsames "Zmorge" vor den Vorträgen).
  const firstStart = [...sessionTimes].sort()[0];
  const existingBreaks = breaksByDay[day] ?? [];
  const hasEarlierProgram = firstStart ? existingBreaks.some(b => b.time < firstStart) : false;
  const openings: DayBreak[] = firstStart
    ? [
        ...(hasEarlierProgram ? [] : [{ time: shiftTime(firstStart, -60), label: "Türöffnung", icon: "" }]),
        { time: shiftTime(firstStart, -30), label: "Begrüssung", icon: "" },
      ]
    : [];
  const dayBreaks = [...openings, ...existingBreaks];

  const breakTimes = dayBreaks.map(b => b.time);
  const allTimes = [...new Set([...sessionTimes, ...breakTimes])].sort();

  return {
    day,
    date: daySessions[0]?.view.date ?? "",
    timeSlots: allTimes.map(time => {
      const breakEntry = dayBreaks.find(b => b.time === time);
      return {
        time,
        isBreak: !!breakEntry,
        breakLabel: breakEntry?.label ?? "",
        breakIcon: breakEntry?.icon ?? "",
        breakCatering: breakEntry?.catering ?? false,
        breakPotluck: breakEntry?.potluck ?? false,
        cells: activeRooms.map(room =>
          daySessions.find(sv => sv.view.startTime === time && sv.view.roomId === room.data.id) ?? null
        ),
      };
    }),
  };
});
---

<PageLayout
  title={t("program.title")}
  description={t("program.lead")}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  breadcrumbs={[{ label: t("program.title") }]}
  fullWidth
>
  <!-- Schwebendes Tages-Inhaltsverzeichnis (Scrollspy) -->
  <nav class="program-toc" aria-label="Tage">
    <ul>
      {timetableData.map(({ day, date }) => {
        const d = new Date(date + "T00:00:00");
        const weekday = d.toLocaleDateString("de-CH", { weekday: "long" });
        const dm = d.toLocaleDateString("de-CH", { day: "numeric", month: "long" });
        return (
          <li>
            <a href={`#day-heading-${day}`} class="program-toc__link" data-toc-day={day}>
              <span class="program-toc__weekday">{weekday}</span>
              <span class="program-toc__date">{dm}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <div class="container">
    <header class="section__header" style="padding-top: var(--space-8);">
      <h1 class="section__title">{t("program.title")}</h1>
      <p class="section__lead"><strong>Drei Tage, zwei Räume, 25+ Vorträge und Workshops.</strong> Meist finden zwei Beiträge gleichzeitig statt – du entscheidest, welcher dich mehr interessiert.</p>
    </header>


  </div>

  <!-- Sessions als Timetable (Zeitslots × Räume) -->
  <div class="container program-list" id="program-list">
    {timetableData.map(({ day, date, timeSlots }) => (
      <section class="program-day" data-day={day} aria-labelledby={`day-heading-${day}`}>
        <h2 class="program-day__heading" id={`day-heading-${day}`}>
          {formatDayFull(date)}
        </h2>

        <div class="timetable" style={`--room-count: ${activeRooms.length}`}>
          <!-- Raum-Header -->
          <div class="timetable__header">
            <div class="timetable__time-col"></div>
            {activeRoomData.map(room => (
              <div class="timetable__room-card">
                <div class="timetable__room-info">
                  {room.icon && <img src={room.icon} alt={room.name} class="timetable__room-icon" />}
                </div>
                {day === 1 && (
                  <div class="timetable__room-intro">
                    <strong class="timetable__room-name">{room.name}</strong>
                    {room.story && <p class="timetable__room-story">{room.story}</p>}
                  </div>
                )}
              </div>
            ))}
          </div>

          <!-- Zeitslot-Zeilen -->
          {timeSlots.map(({ time, isBreak, breakLabel, breakIcon, breakCatering, breakPotluck, cells }) => (
            isBreak ? (
              <div class="timetable__break-row">
                <span class="timetable__break-time">{time}</span>
                <div class="timetable__break">
                  {breakIcon
                    ? <img src={breakIcon} alt={breakLabel} class="timetable__break-icon" />
                    : <span class="timetable__break-label">{breakLabel}</span>}
                  {breakCatering && (
                    <a
                      href="https://spicyroots.ch/"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="timetable__break-catering"
                    >
                      Catering von Spicy Roots
                    </a>
                  )}
                  {breakPotluck && (
                    <span class="timetable__break-note">
                      Potluck-Style – alle bringen etwas mit
                    </span>
                  )}
                </div>
              </div>
            ) : (
              <div class="timetable__row">
                <div class="timetable__time">{time}</div>
                {cells.map(sv => (
                  <div class="timetable__cell">
                    {sv ? (
                      <SessionCard
                        id={sv.view.id}
                        slug={sv.view.slug}
                        title={sv.view.title}
                        description={sv.view.description}
                        type={sv.view.type}
                        language={sv.view.language}
                        startTime={sv.view.startTime}
                        endTime={sv.view.endTime}
                        durationMinutes={sv.view.durationMinutes}
                        day={sv.view.day}
                        date={sv.view.date}
                        roomName={sv.roomName}
                        roomId={sv.view.roomId}
                        speakerNames={sv.speakerNames}
                        speakerPhotos={sv.speakerPhotos}
                        speakerSlugs={sv.speakerSlugs}
                        locale={locale}
                        registrationRequired={sv.view.registrationRequired}
                        recording={sv.view.recording}
                        status={sv.view.status}
                      />
                    ) : (
                      <div class="timetable__empty" aria-hidden="true"></div>
                    )}
                  </div>
                ))}
              </div>
            )
          ))}
        </div>
      </section>
    ))}

  </div>
</PageLayout>

<script src="../../scripts/bookmarks.js"></script>

<script>
  // Tages-TOC: sanftes Scrollen + Scrollspy
  const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>(".program-toc__link")];
  const daySections = [...document.querySelectorAll<HTMLElement>(".program-day")];

  tocLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      const id = link.getAttribute("href")?.slice(1) ?? "";
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      target.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
      history.replaceState(null, "", "#" + id);
    });
  });

  if (tocLinks.length) tocLinks[0].classList.add("is-active");

  if (daySections.length && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const day = entry.target.getAttribute("data-day");
            tocLinks.forEach((l) =>
              l.classList.toggle("is-active", l.getAttribute("data-toc-day") === day)
            );
          }
        });
      },
      { rootMargin: "-45% 0px -50% 0px", threshold: 0 }
    );
    daySections.forEach((s) => observer.observe(s));
  }
</script>

<style>
/* Raum-Geschichten */
.room-stories {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 380px), 1fr));
  gap: var(--space-5);
  margin-bottom: var(--space-12);
}

.room-story {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-6);
  background: transparent;
}

.room-story__photo {
  width: 180px;
  height: 180px;
  object-fit: cover;
  object-position: center 20%;
  flex-shrink: 0;
  -webkit-mask-image: url('/images/yellow-05.png');
  mask-image: url('/images/yellow-05.png');
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

.room-story__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.room-story__icon {
  height: 48px;
  width: auto;
  display: block;
}

.room-story__name {
  font-size: var(--text-lg);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
  margin: 0;
}

.room-story__text {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  max-width: none;
  margin: 0;
}

.timetable__room-intro {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  margin-top: var(--space-2);
}

.timetable__room-name {
  font-size: var(--text-base);
  font-weight: var(--weight-bold);
  color: var(--color-text);
}

.timetable__room-story {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  margin: 0;
  max-width: none;
}

/* Tag-Gruppen */
.program-day {
  margin-bottom: var(--space-10);
}

.program-day__heading {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  font-size: var(--text-2xl);
  margin-bottom: var(--space-5);
  padding-bottom: var(--space-3);
  border-bottom: 2px solid var(--color-primary);
  scroll-margin-top: 100px; /* Offset fuer den sticky Header beim Anspringen */
}

/* Schwebendes Tages-Inhaltsverzeichnis (Scrollspy) */
.program-toc {
  display: none;
}

@media (min-width: 1240px) {
  .program-toc {
    display: block;
    position: fixed;
    left: var(--space-5);
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
  }

  .program-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    border-left: 2px solid var(--color-border);
  }

  .program-toc__link {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: var(--space-2) var(--space-4);
    margin-left: -2px;
    border-left: 2px solid transparent;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .program-toc__weekday {
    font-family: var(--brand-font-bold);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: 1.15;
  }

  .program-toc__date {
    font-size: var(--text-xs);
    opacity: 0.7;
  }

  .program-toc__link:hover {
    color: var(--color-text);
  }

  .program-toc__link.is-active {
    color: var(--color-text);
    border-left-color: var(--color-primary);
  }
}

.program-day__date {
  font-size: var(--text-lg);
  font-weight: var(--weight-normal);
  color: var(--color-text-muted);
}

/* Timetable — Mobile first */
.timetable {
  /* kein overflow-x auf mobile */
}

/* Raum-Header: auf Mobile ausblenden */
.timetable__header {
  display: none;
}

/* Zeitslot-Zeile: auf Mobile gestapelt */
.timetable__row {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.timetable__time {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-muted);
  padding-top: 0;
  text-align: left;
}

.timetable__cell {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.timetable__cell > :global(.session-card) {
  flex: 1;
}

.timetable__empty {
  display: none; /* Leerzellen auf Mobile verstecken */
}

/* Pausen — Mobile */
.timetable__break-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.timetable__break-time {
  font-size: var(--text-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-muted);
  text-align: left;
  flex-shrink: 0;
  width: 48px;
}

.timetable__break {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  background: #e3e3dd;
  border-radius: var(--radius-md);
  padding: var(--space-3) var(--space-4);
}

.timetable__break-icon {
  height: 40px;
  width: auto;
}

.timetable__break-catering {
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: #26282a;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.timetable__break-catering:hover {
  color: var(--color-primary);
}

.timetable__break-note {
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: #26282a;
}

.timetable__break-label {
  font-family: var(--brand-font-bold);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: #26282a;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

/* Raum-Karten */
.timetable__room-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-3);
  padding-bottom: var(--space-4);
  margin-bottom: var(--space-4);
}

.timetable__room-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-3);
}

.timetable__room-icon {
  height: 56px;
  width: auto;
  display: block;
}

.timetable__room-name {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: var(--color-text);
}

.timetable__room-story {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  line-height: var(--leading-snug);
  max-width: none;
  margin: 0;
}

.timetable__time-col {
  /* Platzhalter für die Zeitspalte im Header */
}

/* Desktop: Grid-Layout */
@media (min-width: 640px) {
  .timetable {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .timetable__header {
    display: grid;
    grid-template-columns: 72px repeat(var(--room-count), 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-1);
    align-items: stretch;
    min-width: 480px;
  }

  .timetable__row {
    display: grid;
    flex-direction: unset;
    grid-template-columns: 72px repeat(var(--room-count), 1fr);
    gap: var(--space-3);
    align-items: stretch;
    min-width: 480px;
  }

  .timetable__time {
    padding-top: var(--space-3);
    text-align: right;
    padding-right: var(--space-2);
  }

  .timetable__empty {
    display: block;
    height: 100%;
    min-height: 60px;
    border: 1px dashed rgba(38,40,42,0.12);
    border-radius: var(--radius-lg);
  }

  .timetable__break-row {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-3);
    min-width: 480px;
    align-items: center;
  }

  .timetable__break-time {
    text-align: right;
    padding-right: var(--space-2);
    width: auto;
  }
}

/* Leer */
.program-empty {
  padding: var(--space-12);
  text-align: center;
  color: var(--color-text-muted);
}

/* Ausgeblendet durch Filter */
.program-day[data-hidden] {
  display: none;
}
</style>
