---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";

const locale = "en";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---

<PageLayout
  title={t("registration.success.title")}
  description={t("registration.success.text")}
  locale={locale}
  canonicalUrl={`${site}en/confirmation/`}
  alternates={{ de: `${site}bestaetigung/`, en: `${site}en/confirmation/` }}
  noindex
>
  <div class="section">
    <div class="container--narrow success-page">
      <div class="success-icon" aria-hidden="true">✓</div>
      <h1>{t("registration.success.title")}</h1>
      <p>{t("registration.success.text")}</p>
      <a href="/en/" class="btn btn--primary">{t("registration.success.home")}</a>
    </div>
  </div>
</PageLayout>

<style>
.success-page { text-align: center; padding-block: var(--space-12); }
.success-icon { width: 72px; height: 72px; background: var(--color-success-bg); color: var(--color-success); font-size: 2.5rem; border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--space-6); border: 2px solid var(--color-success); }
.success-page h1 { margin-bottom: var(--space-4); }
.success-page p { color: var(--color-text-muted); margin-bottom: var(--space-8); max-width: 50ch; margin-inline: auto; }
</style>
