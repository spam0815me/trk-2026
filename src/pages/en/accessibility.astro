---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";
const locale = "en";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---
<PageLayout title={t("accessibility.title")} description={t("accessibility.lead")} locale={locale}
  canonicalUrl={`${site}en/accessibility/`} alternates={{ de: `${site}barrierefreiheit/`, en: `${site}en/accessibility/` }}
  breadcrumbs={[{ label: t("accessibility.title") }]}>
  <div class="section prose" style="max-width: var(--max-width-md);">
    <h1>{t("accessibility.title")}</h1>
    <p>{t("accessibility.lead")}</p>
    <h2>Venue</h2>
    <p>All main venues are step-free. Accessible restrooms are available. Details will be added once the venue is confirmed.</p>
    <h2>Register accessibility needs</h2>
    <p>If you have specific support needs (e.g. sign language interpreter, tactile guidance, quieter space), please note this in your registration or <a href="/en/contact">contact us</a> directly.</p>
    <h2>Simultaneous interpretation</h2>
    <p>Simultaneous German/English interpretation is planned for the keynote. Further details to follow.</p>
    <h2>Website accessibility</h2>
    <p>This website aims to meet WCAG 2.1 AA standards. For issues or feedback, <a href="/en/contact">write to us</a>.</p>
  </div>
</PageLayout>
