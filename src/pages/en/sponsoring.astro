---
import PageLayout from "../../layouts/PageLayout.astro";
import PartnerGrid from "../../components/partners/PartnerGrid.astro";
import { useTranslations } from "../../lib/i18n";
import { getCollection } from "astro:content";

const locale = "en";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";

const partnersRaw = await getCollection("partners");
const partners = partnersRaw
  .flatMap(entry => entry.data)
  .sort((a, b) => a.sortOrder - b.sortOrder)
  .map(p => ({ id: p.id, name: p.name, logo: p.logo, url: p.url, category: p.category, description: p.description_en }));

const categories = ["main", "partner", "media", "supporter"] as const;
---
<PageLayout title={t("sponsoring.title")} description={t("sponsoring.lead")} locale={locale}
  canonicalUrl={`${site}en/sponsoring/`} alternates={{ de: `${site}sponsoring/`, en: `${site}en/sponsoring/` }}
  breadcrumbs={[{ label: t("sponsoring.title") }]}>
  <div class="section">
    <header class="section__header">
      <h1 class="section__title">{t("sponsoring.title")}</h1>
      <p class="section__lead">{t("sponsoring.lead")}</p>
    </header>
    {categories.map(cat => {
      const catPartners = partners.filter(p => p.category === cat);
      if (catPartners.length === 0) return null;
      return (
        <section class="sponsors-section">
          <h2 class="sponsors-section__title">{t(`sponsoring.categories.${cat}` as any)}</h2>
          <PartnerGrid partners={catPartners} locale={locale} showDescription />
        </section>
      );
    })}
    <section class="become-partner">
      <h2>{t("sponsoring.becomePartner")}</h2>
      <p>{t("sponsoring.becomePartnerText")}</p>
      <a href="/en/contact" class="btn btn--primary">{t("nav.contact")}</a>
    </section>
  </div>
</PageLayout>
<style>
.sponsors-section { margin-bottom: var(--space-10); }
.sponsors-section__title { font-size: var(--text-xl); margin-bottom: var(--space-5); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border); }
.become-partner { margin-top: var(--space-12); padding: var(--space-8); background: var(--color-primary-subtle); border-radius: var(--radius-xl); border: 1px solid var(--color-primary-light); }
.become-partner h2 { font-size: var(--text-2xl); margin-bottom: var(--space-3); }
.become-partner p { color: var(--color-text-muted); margin-bottom: var(--space-5); }
</style>
