---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";
const locale = "en";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
---
<PageLayout title={t("privacy.title")} description={t("privacy.lead")} locale={locale}
  canonicalUrl={`${site}en/privacy/`} alternates={{ de: `${site}datenschutz/`, en: `${site}en/privacy/` }}
  breadcrumbs={[{ label: t("privacy.title") }]}>
  <div class="section prose" style="max-width: var(--max-width-md);">
    <h1>{t("privacy.title")}</h1>
    <h2>Controller</h2>
    <p>Animal Rights Congress<br />[Address to be added]<br />Email: <a href="mailto:info@tierimfokus.ch">info@tierimfokus.ch</a></p>
    <h2>Processing of registration data</h2>
    <p>When you register for the congress, we process the following data to organise the event: name, email address (required); phone number, dietary preference, and accessibility needs (optional); language preference, ticket category; newsletter consent (optional).</p>
    <p>Legal basis: Art. 6(1)(b) GDPR (pre-contractual measures) and, where applicable, your consent (Art. 6(1)(a) GDPR).</p>
    <h2>Your rights</h2>
    <p>You have the right to access, rectify, erase, restrict processing, portability, and object. Contact <a href="mailto:info@tierimfokus.ch">info@tierimfokus.ch</a>.</p>
    <h2>Cookies & tracking</h2>
    <p>This website uses no tracking cookies and no analytics. Only technically necessary data is processed.</p>
    <p><small>Last updated: April 2026 — please note this is a draft; have it reviewed by a legal professional.</small></p>
  </div>
</PageLayout>
