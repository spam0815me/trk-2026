---
import PageLayout from "../../../layouts/PageLayout.astro";
import { useTranslations, getField } from "../../../lib/i18n";
import { getCollection } from "astro:content";
import { toSessionView, formatDate } from "../../../lib/sessions";

export async function getStaticPaths() {
  const sessions = await getCollection("sessions");
  return sessions
    .filter(s => s.data.year === 2026)
    .map(s => ({ params: { slug: s.data.slug }, props: { session: s } }));
}

const { session } = Astro.props;
const locale = "en";
const t = useTranslations(locale);

const rooms    = await getCollection("rooms");
const speakers = await getCollection("speakers");

const roomEntry       = rooms.find(r => r.data.id === session.data.roomId);
const sessionView     = toSessionView(session, locale);
const roomName        = getField<string>("name", locale, roomEntry?.data as unknown as Record<string, unknown> ?? {});
const accessNote      = getField<string>("accessibility", locale, roomEntry?.data as unknown as Record<string, unknown> ?? {});
const sessionSpeakers = speakers.filter(s => session.data.speakerIds.includes(s.data.id));

// Precomputed for template (TypeScript generics not allowed in JSX expressions)
const speakerDisplayData = sessionSpeakers.map(sp => ({
  href: `/en/speakers/${sp.data.slug}`,
  name: sp.data.name,
  pronouns: sp.data.pronouns,
  organization: sp.data.organization,
  photo: sp.data.photo,
  role: getField<string>("role", locale, sp.data as unknown as Record<string, unknown>),
  bio:  getField<string>("bio",  locale, sp.data as unknown as Record<string, unknown>),
}));

const site         = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
const canonicalUrl = `${site}en/program/${session.data.slug}/`;

const typeLabel = t(`program.types.${session.data.type}` as Parameters<typeof t>[0]);
const langLabel = session.data.language === "de"
  ? t("program.languages.de")
  : session.data.language === "en"
    ? t("program.languages.en")
    : `${t("program.languages.de")} / ${t("program.languages.en")}`;

const roomIcons: Record<string, string> = {
  "saal-a": "/images/Raum_Sandra.svg",
  "saal-b": "/images/Raum_Yvonne.svg",
};
const roomIcon = roomIcons[session.data.roomId];

const icalData = {
  uid: session.data.id,
  title: sessionView.title,
  description: sessionView.description,
  location: roomName,
  startDate: session.data.date,
  startTime: session.data.startTime,
  endTime: session.data.endTime,
  url: canonicalUrl,
};
---

<PageLayout
  title={sessionView.title}
  description={sessionView.description}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={{
    de: `${site}programm/${session.data.slug}/`,
    en: canonicalUrl,
  }}
  breadcrumbs={[
    { label: t("program.title"), href: "/en/program" },
    { label: sessionView.title },
  ]}
>
  <article class="session-detail section">
    <header class="session-detail__header">
      <div class="session-detail__badges">
        <span class:list={["badge", `badge--session-type-${session.data.type}`]}>{typeLabel}</span>
        <span class="badge badge--lang">{langLabel}</span>
        {session.data.registrationRequired && <span class="badge badge--accent">{t("session.registrationRequired")}</span>}
        {session.data.recording && <span class="badge">{t("session.recording")}</span>}
      </div>
      <h1 class="session-detail__title">{sessionView.title}</h1>
      <dl class="session-detail__meta">
        <div class="session-detail__meta-item">
          <dt>{t("program.day")}</dt>
          <dd>{formatDate(session.data.date, locale)}</dd>
        </div>
        <div class="session-detail__meta-item">
          <dt>{t("program.time")}</dt>
          <dd><time>{session.data.startTime}–{session.data.endTime}</time> ({sessionView.durationMinutes} {t("session.minutes")})</dd>
        </div>
        <div class="session-detail__meta-item">
          <dt>{t("session.room")}</dt>
          <dd>
            {roomIcon
              ? <img src={roomIcon} alt={roomName} class="room-name-icon" />
              : roomName
            }
          </dd>
        </div>
        {session.data.capacity && (
          <div class="session-detail__meta-item">
            <dt>{t("session.capacity")}</dt>
            <dd>{session.data.capacity} seats</dd>
          </div>
        )}
      </dl>
      <div class="session-detail__actions">
        <button class="bookmark-btn btn btn--ghost" data-session-id={session.data.id} type="button">
          <span class="btn-icon" style="--icon-url: url('/images/x-separator.svg'); width: 16px; height: 16px;" aria-hidden="true"></span>
          <span class="bookmark-btn__label">{t("program.addToBookmarks")}</span>
        </button>
        <button class="ical-btn btn btn--ghost" data-ical={JSON.stringify(icalData)} data-filename={`arc-2026-${session.data.slug}`} type="button">
          <span class="btn-icon" style="--icon-url: url('/images/calendar.svg'); width: 20px; height: 20px;" aria-hidden="true"></span>
          {t("session.exportIcal")}
        </button>
      </div>
    </header>

    <div class="session-detail__body prose">
      {sessionView.longDescription ? (
        <p set:html={sessionView.longDescription} />
      ) : (
        <p>{sessionView.description}</p>
      )}
      {sessionView.notes && (
        <aside class="session-detail__note">
          <strong>Note:</strong> {sessionView.notes}
        </aside>
      )}
    </div>

    {accessNote && (
      <aside class="session-detail__access">
        <h2>{t("session.accessibilityNotes")}</h2>
        <p>{accessNote}</p>
      </aside>
    )}

    {sessionSpeakers.length > 0 && (
      <section class="session-detail__speakers">
        <h2>{t("session.speakers")}</h2>
        <ul class="session-speakers-list" role="list">
          {speakerDisplayData.map(sp => (
            <li class="session-speaker">
              {sp.photo && (
                <a href={sp.href} tabindex="-1" aria-hidden="true">
                  <img src={sp.photo} alt="" class="session-speaker__photo" width="80" height="80" loading="lazy" />
                </a>
              )}
              <div class="session-speaker__info">
                <h3 class="session-speaker__name">
                  <a href={sp.href}>{sp.name}</a>
                </h3>
                <p class="session-speaker__role">{sp.role}{sp.organization ? `, ${sp.organization}` : ""}</p>
                <p class="session-speaker__bio">{sp.bio}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <nav class="session-detail__back">
      <a href="/en/program" class="btn btn--primary">
        <span class="btn-icon" style="--icon-url: url('/images/back.svg'); width: 16px; height: 16px;" aria-hidden="true"></span>
        {t("session.back")}
      </a>
    </nav>
  </article>
</PageLayout>

<script>
  import { generateICalEvent, downloadIcal } from "../../../lib/ical.ts";
  import type { ICalEvent } from "../../../lib/ical.ts";
  document.querySelectorAll<HTMLButtonElement>(".ical-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      try {
        const data = JSON.parse(btn.dataset.ical ?? "{}") as ICalEvent;
        downloadIcal(generateICalEvent(data), btn.dataset.filename ?? "session");
      } catch (e) { console.error(e); }
    });
  });
</script>
<script src="../../../scripts/bookmarks.js" type="module"></script>

<style>
.session-detail { max-width: var(--max-width-lg); }
.session-detail__header { margin-bottom: var(--space-8); }
.session-detail__badges { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4); }
.session-detail__title { margin-bottom: var(--space-5); }
.session-detail__title { margin-bottom: var(--space-5); }
.session-detail__meta { display: flex; flex-wrap: wrap; align-items: baseline; gap: var(--space-2) var(--space-6); margin-bottom: var(--space-6); font-size: var(--text-sm); }
.session-detail__meta-item { display: flex; flex-direction: column; align-items: flex-start; gap: 0; }
.session-detail__meta-item dt, .session-detail__meta-item dd { font-family: 'Cubano', var(--brand-font-bold); font-weight: var(--weight-normal); }
.session-detail__meta-item dt { color: #26282a; text-transform: uppercase; }
.session-detail__meta-item dd { color: #e5b969; margin: 0; }
.session-detail__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: flex-start; }
.session-detail__actions .btn { flex: 0 0 13rem; width: 13rem; display: inline-flex; align-items: center; justify-content: center; }
.session-detail__body { margin-bottom: var(--space-8); }
.session-detail__note { background: var(--color-warning-bg); border-left: 3px solid var(--color-warning); padding: var(--space-4); border-radius: var(--radius-md); font-size: var(--text-sm); }
.session-detail__access { background: var(--color-bg-subtle); border-radius: var(--radius-lg); padding: var(--space-5); margin-bottom: var(--space-8); }
.session-detail__access h2 { font-size: var(--text-base); margin-bottom: var(--space-2); }
.session-detail__speakers { margin-bottom: var(--space-8); }
.session-detail__speakers h2 { font-size: var(--text-xl); margin-bottom: var(--space-5); }
.session-speakers-list { display: flex; flex-direction: column; gap: var(--space-5); list-style: none; }
.session-speaker { display: flex; gap: var(--space-5); align-items: flex-start; padding: var(--space-5); background: #26282a; border-radius: var(--radius-lg); }
.session-speaker__photo { width: 80px; height: 80px; border-radius: var(--radius-full); object-fit: cover; flex-shrink: 0; }
.session-speaker__name { font-size: var(--text-lg); margin-bottom: var(--space-1); }
.session-speaker__name a { color: #e3e3dd; text-decoration: none; }
.session-speaker__name a:hover { color: #e5b969; }
.session-speaker__pronouns { font-size: var(--text-sm); font-weight: var(--weight-normal); color: #e3e3dd; }
.session-speaker__role { font-size: var(--text-sm); color: #e5b969; font-weight: var(--weight-medium); margin-bottom: var(--space-2); max-width: none; }
.session-speaker__bio { font-size: var(--text-sm); color: #fafaff; }
.session-detail__back { padding-top: var(--space-6); border-top: 1px solid var(--color-border); }
</style>
