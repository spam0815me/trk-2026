---
import PageLayout from "../../../layouts/PageLayout.astro";
import SessionCard from "../../../components/program/SessionCard.astro";
import { useTranslations, getField } from "../../../lib/i18n";
import { getCollection } from "astro:content";
import { getCurrentSessions, toSessionView } from "../../../lib/sessions";

const locale = "en";
const t = useTranslations(locale);

const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
const canonicalUrl = `${site}en/program/bookmarks/`;
const alternates = {
  de: `${site}programm/merkliste/`,
  en: canonicalUrl,
};

const sessions = await getCurrentSessions(2026);
const rooms    = await getCollection("rooms");
const speakers = await getCollection("speakers");

const roomMap    = Object.fromEntries(rooms.map(r => [r.data.id, r]));
const speakerMap = Object.fromEntries(speakers.map(s => [s.data.id, s]));

const sessionViews = sessions.map(s => ({
  view: toSessionView(s, locale),
  roomName: getField<string>("name", locale, roomMap[s.data.roomId]?.data as unknown as Record<string, unknown> ?? {}),
  speakerNames: s.data.speakerIds.map(id => speakerMap[id]?.data.name ?? ""),
  speakerPhotos: s.data.speakerIds.map(id => speakerMap[id]?.data.photo ?? ""),
  speakerSlugs: s.data.speakerIds.map(id => speakerMap[id]?.data.slug ?? ""),
}));
---

<PageLayout
  title={t("bookmarks.title")}
  description="Your saved sessions at a glance."
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  breadcrumbs={[
    { label: t("program.title"), href: "/en/program/" },
    { label: t("bookmarks.title") },
  ]}
  fullWidth
>
  <div class="container">
    <header class="section__header" style="padding-top: var(--space-8);">
      <h1 class="section__title">{t("bookmarks.title")}</h1>
    </header>
  </div>

  <div class="container bookmarks-toolbar">
    <p class="program-count" id="bookmark-count" aria-live="polite" aria-atomic="true">
      <span id="count-num">0</span> sessions saved
    </p>
    <a href="/en/program/" class="btn btn--secondary btn--sm">{t("bookmarks.goToProgram")}</a>
  </div>

  <div class="container program-list" id="bookmark-list">
    {sessionViews.map(({ view, roomName, speakerNames, speakerPhotos, speakerSlugs }) => (
      <div class="bookmark-item" data-session-id={view.id} hidden>
        <SessionCard
          id={view.id}
          slug={view.slug}
          title={view.title}
          description={view.description}
          type={view.type}
          language={view.language}
          startTime={view.startTime}
          endTime={view.endTime}
          durationMinutes={view.durationMinutes}
          day={view.day}
          date={view.date}
          roomName={roomName}
          roomId={view.roomId}
          speakerNames={speakerNames}
          speakerPhotos={speakerPhotos}
          speakerSlugs={speakerSlugs}
          locale={locale}
          registrationRequired={view.registrationRequired}
          recording={view.recording}
          status={view.status}
        />
      </div>
    ))}

    <div id="empty-state" class="bookmarks-empty">
      <p><strong>{t("bookmarks.empty")}</strong></p>
      <p>{t("bookmarks.emptyHint")}</p>
      <a href="/en/program/" class="btn btn--primary" style="margin-top: var(--space-4);">
        {t("bookmarks.goToProgram")}
      </a>
    </div>
  </div>
</PageLayout>

<script src="../../../scripts/bookmarks.js"></script>
<script>
  const STORAGE_KEY = "trk2026_bookmarks";

  function getBookmarks() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? "[]"); }
    catch { return []; }
  }

  function render() {
    const ids = getBookmarks();
    const items = document.querySelectorAll(".bookmark-item[data-session-id]");
    let count = 0;

    items.forEach(item => {
      const id = item.dataset.sessionId ?? "";
      const visible = ids.includes(id);
      item.hidden = !visible;
      if (visible) count++;
    });

    const countEl = document.getElementById("count-num");
    if (countEl) countEl.textContent = String(count);

    const empty = document.getElementById("empty-state");
    if (empty) empty.hidden = count > 0;
  }

  render();

  window.addEventListener("bookmarks-changed", render);
  window.addEventListener("storage", e => {
    if (e.key === STORAGE_KEY) render();
  });
</script>

<style>
.bookmarks-toolbar {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
}
.program-count {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  max-width: none;
  margin: 0;
}
.program-list {
  display: grid;
  gap: var(--space-4);
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 400px), 1fr));
  margin-bottom: var(--space-12);
}
.bookmarks-empty {
  grid-column: 1 / -1;
  padding: var(--space-12);
  text-align: center;
  color: var(--color-text-muted);
}
</style>
