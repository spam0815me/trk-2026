---
import PageLayout from "../../layouts/PageLayout.astro";
import { useTranslations } from "../../lib/i18n";
const locale = "en";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
---
<PageLayout title={t("venue.title")} description={t("venue.lead")} locale={locale}
  canonicalUrl={`${site}en/venue/`} alternates={{ de: `${site}ort/`, en: `${site}en/venue/` }}
  breadcrumbs={[{ label: t("venue.title") }]}>
  <div class="section">
    <header class="section__header">
      <h1 class="section__title">{t("venue.title")}</h1>
      <p class="section__lead">{t("venue.lead")}</p>
    </header>
    <div class="venue-map">
      <iframe
        src="https://www.google.com/maps?q=Photobastei,+Sihlquai+125,+8005+Z%C3%BCrich&output=embed"
        width="100%"
        height="420"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Photobastei Zürich location"
        aria-label="Google Maps: Photobastei, Sihlquai 125, 8005 Zürich"
      ></iframe>
    </div>
    <section class="venue-sections">
      <div class="venue-section">
        <h2>{t("venue.address")}</h2>
        <address>
          <strong>Photobastei Zürich</strong><br />
          Sihlquai 125<br />
          8005 Zürich
        </address>
      </div>
      <div class="venue-section">
        <h2>{t("venue.publicTransport")}</h2>
        <p>Photobastei is well connected by public transport. The nearest train station is Zürich HB (approx. 10 minutes on foot). Several tram and bus lines stop nearby.</p>
      </div>
      <div class="venue-section">
        <h2>{t("venue.accessibility")}</h2>
        <p>We are committed to ensuring the venue is fully accessible. For specific support needs, please <a href="/en/contact">contact us</a>.</p>
      </div>
    </section>
  </div>
</PageLayout>
<style>
.venue-map { margin-bottom: var(--space-10); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); }
.venue-sections { display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr)); }
.venue-section { padding: var(--space-6); background: #e3e3dd; border-radius: var(--radius-lg); }
.venue-section h2 { font-size: var(--text-lg); margin-bottom: var(--space-3); }
.venue-section p, .venue-section address { color: var(--color-text-muted); font-style: normal; line-height: var(--leading-relaxed); max-width: none; }
</style>
