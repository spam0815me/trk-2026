---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/ui/Hero.astro";
import CTABlock from "../../components/ui/CTABlock.astro";
import SpeakerCard from "../../components/speakers/SpeakerCard.astro";
import PartnerGrid from "../../components/partners/PartnerGrid.astro";
import { useTranslations, getField } from "../../lib/i18n";
import { getCollection } from "astro:content";
import { congressEventJsonLd, organizationJsonLd } from "../../lib/seo-jsonld";

const locale = "en";
const t = useTranslations(locale);

const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
const canonicalUrl = `${site}en/`;
const alternates = { de: `${site}`, en: canonicalUrl };

const ogImageAbs = new URL("/images/og-default.jpg", site).toString();
const jsonLd = [
  congressEventJsonLd({ locale, url: canonicalUrl, image: ogImageAbs, description: t("site.shareDescription") }),
  organizationJsonLd(),
];

const speakersRaw = await getCollection("speakers");
const speakers = speakersRaw
  .filter(s => s.data.year === 2026)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 4);

const partnersRaw = await getCollection("partners");
const partners = partnersRaw.flatMap(entry => entry.data).sort((a, b) => a.sortOrder - b.sortOrder);
---

<BaseLayout
  title={t("site.name")}
  description={t("site.description")}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <Hero
    lead={t("home.heroLead")}
    ctaPrimary={{ href: "/en/registration", label: t("home.ctaRegister") }}
    ctaSecondary={{ href: "/en/program", label: t("home.ctaProgram") }}
    size="large"
    pushDown
  />

  <section class="section section--sm" aria-labelledby="speakers-home-en" style="background: var(--color-bg-subtle);">
    <div class="container">
      <header class="section__header">
        <h2 id="speakers-home-en" class="section__title">{t("home.speakersTitle")}</h2>
        <p class="section__lead">{t("home.speakersLead")}</p>
      </header>
      <div class="grid grid--4">
        {speakers.map(s => (
          <SpeakerCard
            id={s.data.id}
            slug={s.data.slug}
            name={s.data.name}
            pronouns={s.data.pronouns}
            role={getField("role", locale, s.data as unknown as Record<string, unknown>)}
            organization={s.data.organization}
            bio={getField("bio", locale, s.data as unknown as Record<string, unknown>)}
            photo={s.data.photo}
            sessionCount={s.data.sessionIds.length}
            locale={locale}
          />
        ))}
      </div>
      <div style="margin-top: var(--space-8); text-align: center;">
        <a href="/en/speakers" class="btn btn--secondary">{t("home.speakersAll")}</a>
      </div>
    </div>
  </section>


</BaseLayout>
