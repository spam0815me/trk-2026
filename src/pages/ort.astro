---
import PageLayout from "../layouts/PageLayout.astro";
import { useTranslations } from "../lib/i18n";

const locale = "de";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
---

<PageLayout
  title={t("venue.title")}
  description={t("venue.lead")}
  locale={locale}
  canonicalUrl={`${site}ort/`}
  alternates={{ de: `${site}ort/`, en: `${site}en/venue/` }}
  breadcrumbs={[{ label: t("venue.title") }]}
>
  <div class="section">
    <header class="section__header">
      <h1 class="section__title">{t("venue.title")}</h1>
      <p class="section__lead">{t("venue.lead")}</p>
    </header>

    <div class="venue-map">
      <iframe
        src="https://www.google.com/maps?q=Photobastei,+Sihlquai+125,+8005+Z%C3%BCrich&output=embed"
        width="100%"
        height="420"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Standort Photobastei Zürich"
        aria-label="Google Maps Karte: Photobastei, Sihlquai 125, 8005 Zürich"
      ></iframe>
    </div>

    <section class="venue-sections">
      <div class="venue-section">
        <h2 class="venue-section__title">
          <img src="/images/Photobastei.svg" alt="" class="venue-icon" aria-hidden="true" />
          {t("venue.address")}
        </h2>
        <address>
          <strong>Photobastei Zürich</strong><br />
          Sihlquai 125<br />
          8005 Zürich
        </address>
      </div>

      <div class="venue-section">
        <h2 class="venue-section__title">
          <img src="/images/OeV.svg" alt="" class="venue-icon" aria-hidden="true" />
          Anreise
        </h2>
        <p>Wir empfehlen die Anreise mit dem öffentlichen Verkehr. Die Photobastei ist vom Zürcher Hauptbahnhof (Zürich HB) zu Fuss in rund 10 Minuten erreichbar – oder mit der Tramlinie 17 ab der Haltestelle Sihlquai/HB.</p>
      </div>

      <div class="venue-section">
        <h2 class="venue-section__title">
          <img src="/images/behinderte-person.svg" alt="" class="venue-icon" aria-hidden="true" />
          {t("venue.accessibility")}
        </h2>
        <p>Wir stellen sicher, dass der Veranstaltungsort barrierefrei zugänglich ist. Bei spezifischem Unterstützungsbedarf <a href="/kontakt">kontaktiere uns</a>.</p>
        <p><a href="/barrierefreiheit">Weitere Informationen zur Barrierefreiheit</a></p>
      </div>
    </section>
  </div>
</PageLayout>

<style>
.venue-map {
  margin-bottom: var(--space-10);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.venue-placeholder {
  padding: var(--space-8);
  background: var(--color-bg-subtle);
  border: 2px dashed var(--color-border-strong);
  border-radius: var(--radius-lg);
  text-align: center;
  margin-bottom: var(--space-8);
  color: var(--color-text-muted);
}

.venue-sections {
  display: grid;
  gap: var(--space-6);
  grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
}

.venue-section {
  padding: var(--space-6);
  background: #e3e3dd;
  border-radius: var(--radius-lg);
}

.venue-section h2 {
  font-size: var(--text-lg);
  margin-bottom: var(--space-3);
}

.venue-section__title {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-3);
}

.venue-icon {
  height: 80px;
  width: auto;
  flex-shrink: 0;
  display: block;
}

.venue-section p, .venue-section address {
  color: var(--color-text-muted);
  font-style: normal;
  line-height: var(--leading-relaxed);
  max-width: none;
}
</style>
