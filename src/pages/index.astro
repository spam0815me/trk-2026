---
/**
 * Startseite — Deutsch (Default-Locale)
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import CTABlock from "../components/ui/CTABlock.astro";
import SpeakerCard from "../components/speakers/SpeakerCard.astro";
import PartnerGrid from "../components/partners/PartnerGrid.astro";
import { useTranslations, getField } from "../lib/i18n";
import { getCollection } from "astro:content";
import { congressEventJsonLd, organizationJsonLd } from "../lib/seo-jsonld";

const locale = "de";
const t = useTranslations(locale);

const site = Astro.site?.toString() ?? "https://tierrechtskongress.ch";
const canonicalUrl = site;
const alternates = {
  de: canonicalUrl,
  en: `${site}en/`,
};

const ogImageAbs = new URL("/images/og-default.jpg", site).toString();
const jsonLd = [
  congressEventJsonLd({ locale, url: canonicalUrl, image: ogImageAbs, description: t("site.shareDescription") }),
  organizationJsonLd(),
];

// Daten laden
const speakersRaw = await getCollection("speakers");
const speakers = speakersRaw
  .filter(s => s.data.year === 2026)
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const partnersRaw = await getCollection("partners");
const partners = partnersRaw.flatMap(entry => entry.data).sort((a, b) => a.sortOrder - b.sortOrder);

// Highlights (⭐ Sessions)
const sessionsRaw = await getCollection("sessions");
const speakerMap = Object.fromEntries(speakersRaw.map(s => [s.data.id, s]));
const roomIcons: Record<string, string> = {
  "saal-a": "/images/Raum_Sandra.svg",
  "saal-b": "/images/Raum_Yvonne.svg",
};
const dayLabels: Record<number, string> = {
  1: "Fr 23. Oktober",
  2: "Sa 24. Oktober",
  3: "So 25. Oktober",
};
const highlights = sessionsRaw
  .filter(s => s.data.highlight && s.data.year === 2026)
  .sort((a, b) => a.data.day - b.data.day || a.data.startTime.localeCompare(b.data.startTime))
  .map(s => {
    const sp = speakerMap[s.data.speakerIds[0]];
    return {
      slug: s.data.slug,
      title: s.data.title_de,
      description: s.data.description_de,
      startTime: s.data.startTime,
      dayLabel: dayLabels[s.data.day] ?? "",
      roomId: s.data.roomId,
      roomIcon: roomIcons[s.data.roomId] ?? null,
      speakerName: sp?.data.name ?? "",
      speakerRole: getField<string>("role", locale, sp?.data as unknown as Record<string, unknown> ?? {}),
      speakerOrg: sp?.data.organization ?? "",
      speakerPhoto: sp?.data.photo ?? "",
    };
  });
---

<BaseLayout
  title={t("site.name")}
  description={t("site.description")}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <Hero
    lead={t("home.heroLead")}
    ctaPrimary={{ href: "/anmeldung", label: t("home.ctaRegister") }}
    size="large"
    pushDown
  />

  <!-- Kongress-Info -->
  <section class="section" aria-labelledby="info-title">
    <div class="container">
      <div class="home-info">

        <!-- Datum -->
        <div class="home-info__item">
          <div class="home-info__icon-wrap" aria-hidden="true">
            <img src="/images/Tag.svg" alt="" class="home-info__tag-icon" />
          </div>
          <div>
            <strong>23.–25. Oktober 2026</strong>
            <p>Drei Tage Programm</p>
          </div>
        </div>

        <!-- Ort -->
        <div class="home-info__item">
          <div class="home-info__icon-wrap" aria-hidden="true">
            <img src="/images/Photobastei.svg" alt="" class="home-info__tag-icon" />
          </div>
          <div>
            <strong>Photobastei Zürich</strong>
            <p>Sihlquai 125, 8005 Zürich</p>
          </div>
        </div>

        <!-- Sessions -->
        <div class="home-info__item">
          <div class="home-info__icon-wrap" aria-hidden="true">
            <img src="/images/Events.svg" alt="" class="home-info__tag-icon" />
          </div>
          <div>
            <strong>40+ Sessions</strong>
            <p>Vorträge &amp; Workshops</p>
          </div>
        </div>

        <!-- Sprache -->
        <div class="home-info__item">
          <div class="home-info__icon-wrap" aria-hidden="true">
            <img src="/images/Sprache.svg" alt="" class="home-info__tag-icon" />
          </div>
          <div>
            <strong>DE / EN</strong>
            <p>Meist Deutsch</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Programm-Highlights Karussell -->
  <section class="hl-block" aria-label="Programm-Highlights">
    <div class="hl-carousel" id="hl-carousel">
      {highlights.map((h, i) => (
        <div class:list={["hl-slide", { "hl-slide--active": i === 0 }]} aria-hidden={i !== 0 ? "true" : undefined}>
          <div class="hl-block__inner container">
            {h.speakerPhoto && (
              <img src={h.speakerPhoto} alt={h.speakerName} class="hl-block__photo" />
            )}
            <div class="hl-block__content">
              <p class="hl-block__label">Programm-Highlight</p>
              <div class="hl-block__meta">
                <span class="hl-block__meta-item">
                  <img src="/images/Tag.svg" alt="" width="28" height="28" aria-hidden="true" />
                  {h.dayLabel}
                </span>
                <span class="hl-block__meta-item">
                  <img src="/images/Uhrzeit.svg" alt="" width="28" height="28" aria-hidden="true" />
                  {h.startTime}
                </span>
                {h.roomIcon && (
                  <span class="hl-block__meta-item">
                    <img src={h.roomIcon} alt="" class="hl-block__room-icon" aria-hidden="true" />
                  </span>
                )}
              </div>
              <h2 class="hl-block__title">{h.title}</h2>
              <p class="hl-block__desc">{h.description}</p>
              <div class="hl-block__speaker">
                <strong>{h.speakerName}</strong>
                {(h.speakerRole || h.speakerOrg) && (
                  <span>{[h.speakerRole, h.speakerOrg].filter(Boolean).join(", ")}</span>
                )}
              </div>
              <div class="hl-block__actions">
                <a href={`/programm/${h.slug}`} class="hl-action-btn">
                  <span class="btn-icon" style="--icon-url: url('/images/Love.svg'); width: 20px; height: 20px; background-color: #fafaff;" aria-hidden="true"></span>
                  Zum Vortrag
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pfeile -->
    <button class="hl-arrow hl-arrow--prev" id="hl-prev" aria-label="Vorheriges Highlight">
      <img src="/images/back.svg" alt="" width="36" height="36" />
    </button>
    <button class="hl-arrow hl-arrow--next" id="hl-next" aria-label="Nächstes Highlight">
      <img src="/images/forward.svg" alt="" width="36" height="36" />
    </button>
  </section>

  <!-- Referent:innen -->
  <section class="section section--sm" aria-labelledby="speakers-home-title" style="background: #26282a; margin-top: var(--space-16);">
    <div class="container">
      <header class="section__header">
        <h2 class="section__title" id="speakers-home-title" style="color: #fafaff;">{t("home.speakersTitle")}</h2>
        <p class="section__lead" style="color: #e3e3dd;">{t("home.speakersLead")}</p>
      </header>
      <div class="speakers-random" id="speakers-home">
        {speakers.map(s => (
          <SpeakerCard
            id={s.data.id}
            slug={s.data.slug}
            name={s.data.name}
            pronouns={s.data.pronouns}
            role={getField("role", locale, s.data as unknown as Record<string, unknown>)}
            organization={s.data.organization}
            bio={getField("bio", locale, s.data as unknown as Record<string, unknown>)}
            photo={s.data.photo}
            sessionCount={s.data.sessionIds.length}
            locale={locale}
          />
        ))}
      </div>
      <div style="margin-top: var(--space-8); text-align: center;">
        <a href="/referentinnen" class="btn btn--organic-yellow btn--speakers-all">{t("home.speakersAll")}</a>
      </div>
    </div>
  </section>

  <!-- Partner:innen -->
  {partners.length > 0 && (
    <section class="section section--sm" aria-labelledby="partners-home-title">
      <div class="container">
        <header class="section__header">
          <h2 class="section__title" id="partners-home-title">{t("home.partnersTitle")}</h2>
        </header>
        <PartnerGrid partners={partners.map(p => ({
          id: p.id,
          name: p.name,
          logo: p.logo,
          url: p.url,
          category: p.category,
        }))} locale={locale} />
      </div>
    </section>
  )}


</BaseLayout>

<script src="../scripts/bookmarks.js"></script>

<style>
.btn--speakers-all:hover {
  background-image: url('/images/btn-v2-beige.svg') !important;
  color: #26282a !important;
}

/* Referent:innen — Mobile Karussell */
.speakers-random {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  gap: var(--space-4);
  padding-bottom: var(--space-4);
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.speakers-random::-webkit-scrollbar {
  display: none;
}

.speakers-random > :global(.speaker-card) {
  scroll-snap-align: start;
  flex: 0 0 80%;
  min-width: 260px;
  max-width: 320px;
}

@media (min-width: 640px) {
  .speakers-random {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    overflow-x: visible;
    scroll-snap-type: none;
    justify-content: center;
    padding-bottom: 0;
  }

  .speakers-random > :global(.speaker-card) {
    flex: unset;
    min-width: unset;
    max-width: unset;
  }
}
/* ── Highlight Karussell ─────────────────────────────────── */
.hl-block {
  background: #e3e3dd;
}

.hl-carousel {
  position: relative;
  overflow: hidden;
}

.hl-slide {
  display: none;
  padding: var(--space-16) 0;
  opacity: 0;
  filter: blur(6px);
  transition: opacity 0.5s ease, filter 0.5s ease;
}

.hl-slide--active {
  display: block;
  opacity: 1;
  filter: blur(0);
}

/* Pfeile: absolut positioniert links/rechts vom Foto */
.hl-block {
  position: relative;
}

.hl-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  opacity: 0.6;
  transition: opacity 0.2s;
  z-index: 2;
}

.hl-arrow:hover {
  opacity: 1;
}

.hl-arrow--prev {
  left: var(--space-4);
}

.hl-arrow--next {
  right: var(--space-4);
  left: auto;
}

.hl-block__inner {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: var(--space-12);
  align-items: center;
}

.hl-block__photo {
  width: 280px;
  height: 280px;
  object-fit: cover;
  object-position: top center;
  flex-shrink: 0;
  -webkit-mask-image: url('/images/yellow-05.png');
  mask-image: url('/images/yellow-05.png');
  -webkit-mask-size: contain;
  mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
}

.hl-block__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.hl-block__label {
  font-size: var(--text-xs);
  font-weight: var(--weight-semibold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #e5b969;
  margin: 0;
  max-width: none;
}

.hl-block__meta {
  display: flex;
  gap: var(--space-4);
  flex-wrap: wrap;
  align-items: center;
}

.hl-block__meta-item {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: #26282a;
}

.hl-block__room-icon {
  height: 28px;
  width: auto;
}

.hl-room-icon {
  height: 36px;
  width: auto;
  filter: brightness(0);
}

.hl-block__title {
  font-size: var(--text-3xl);
  font-weight: var(--weight-bold);
  line-height: 1.2;
  color: #26282a;
  margin: 0;
}

.hl-block__desc {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
  max-width: none;
}

.hl-block__speaker {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding-top: var(--space-2);
  border-top: 1px solid rgba(38, 40, 42, 0.15);
}

.hl-block__speaker strong {
  font-size: var(--text-sm);
  font-weight: var(--weight-semibold);
  color: #26282a;
}

.hl-block__speaker span {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}

@media (max-width: 640px) {
  .hl-block__inner {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
  }

  .hl-block__meta,
  .hl-block__speaker,
  .hl-block__actions {
    justify-content: center;
  }

  .hl-block__title {
    font-size: var(--text-2xl);
  }

  .hl-block__meta-item img {
    width: 18px;
    height: 18px;
  }

  .hl-block__room-icon {
    height: 18px;
  }

  /* Button grösser auf Mobile */
  .hl-action-btn {
    height: 60px;
    font-size: 20px;
    padding: 0 32px;
  }

  /* Pfeile unterhalb des Fotos, an den unteren Ecken */
  .hl-arrow {
    top: auto;
    transform: none;
    bottom: var(--space-6);
  }

  .hl-arrow--prev {
    left: var(--space-4);
  }

  .hl-arrow--next {
    right: var(--space-4);
    left: auto;
  }
}

.hl-block__actions {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.hl-action-btn,
.hl-bookmark-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 48px;
  padding: 0 24px;
  box-sizing: border-box;
  background-image: url('/images/btn-v2-black.svg');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-color: transparent;
  border: none;
  font-family: var(--brand-font-bold);
  font-size: 16px;
  font-weight: var(--weight-semibold);
  color: #fafaff;
  text-decoration: none;
  cursor: pointer;
  white-space: nowrap;
  line-height: 1;
  transition: opacity 0.2s;
}

.hl-action-btn:hover {
  background-image: url('/images/btn-v2-yellow.svg');
  color: #26282a;
  opacity: 1;
}

.hl-action-btn .btn-icon,
.hl-bookmark-btn .btn-icon {
  background-color: #fafaff;
}

.hl-bookmark-btn.is-bookmarked .bookmark-btn__label {
  color: #e5b969;
}

.hl-bookmark-btn.is-bookmarked .btn-icon {
  background-color: #e5b969;
}

/* ── Organizer ───────────────────────────────────────────── */
.home-organizer {
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-6) 0;
}

.home-organizer__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
}

.home-organizer__label {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

.home-organizer__logo {
  height: 36px;
  width: auto;
}


.home-info {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-6);
}

@media (min-width: 640px) {
  .home-info {
    grid-template-columns: repeat(4, 1fr);
  }
}

.home-info__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-4);
}

.home-info__icon-wrap {
  position: relative;
  width: 90px;
  height: 90px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

@media (min-width: 640px) {
  .home-info__icon-wrap {
    width: 140px;
    height: 140px;
  }
}

.home-info__shape {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.home-info__svg {
  position: absolute;
  inset: 0;
  width: 65%;
  height: 65%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.home-info__tag-icon {
  width: 90px;
  height: 90px;
  object-fit: contain;
}

@media (min-width: 640px) {
  .home-info__tag-icon {
    width: 140px;
    height: 140px;
  }
}

.home-info__item strong {
  display: block;
  font-weight: var(--weight-bold);
  font-size: var(--text-lg);
  margin-bottom: var(--space-1);
}

@media (min-width: 640px) {
  .home-info__item strong {
    font-size: var(--text-xl);
  }
}

.home-info__item > div {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.home-info__item p {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  max-width: none;
}

@media (min-width: 640px) {
  .home-info__item p {
    font-size: var(--text-base);
  }
}

@media (min-width: 640px) {
  .home-info__item p {
    font-size: var(--text-base);
  }
}
</style>

<script>
  document.querySelectorAll<HTMLElement>(".home-info__shape").forEach(el => {
    const deg = Math.floor(Math.random() * 360);
    el.style.transform = `rotate(${deg}deg)`;
  });

  // Zufällige Auswahl von 5 Referent:innen bei jedem Laden
  const grid = document.getElementById("speakers-home");
  if (grid) {
    const cards = Array.from(grid.children) as HTMLElement[];
    cards.forEach(c => c.style.display = "none");
    const shuffled = cards.sort(() => Math.random() - 0.5).slice(0, 4);
    shuffled.forEach(c => c.style.display = "");
  }

  // Highlights Karussell
  const slides = Array.from(document.querySelectorAll<HTMLElement>(".hl-slide"));
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].classList.remove("hl-slide--active");
    slides[current].setAttribute("aria-hidden", "true");
    current = (index + slides.length) % slides.length;
    // Kurz warten damit der Blur-Out sichtbar ist, dann einblenden
    requestAnimationFrame(() => {
      slides[current].classList.add("hl-slide--active");
      slides[current].removeAttribute("aria-hidden");
    });
  }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), 10000);
  }

  document.getElementById("hl-next")?.addEventListener("click", () => { goTo(current + 1); startTimer(); });
  document.getElementById("hl-prev")?.addEventListener("click", () => { goTo(current - 1); startTimer(); });

  startTimer();

</script>
