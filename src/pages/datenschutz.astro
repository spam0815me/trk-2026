---
import PageLayout from "../layouts/PageLayout.astro";
import { useTranslations } from "../lib/i18n";

const locale = "de";
const t = useTranslations(locale);
const site = Astro.site?.toString() ?? "https://tierrechtskongress.de";
---

<PageLayout
  title={t("privacy.title")}
  description={t("privacy.lead")}
  locale={locale}
  canonicalUrl={`${site}datenschutz/`}
  alternates={{ de: `${site}datenschutz/`, en: `${site}en/privacy/` }}
  breadcrumbs={[{ label: t("privacy.title") }]}
>
  <div class="section prose" style="max-width: var(--max-width-md);">
    <h1>{t("privacy.title")}</h1>

    <h2>Verantwortliche Stelle</h2>
    <p>
      Tier im Fokus (TIF)<br />
      Postfach 3159<br />
      3001 Bern<br />
      <a href="mailto:info@tierimfokus.ch">info@tierimfokus.ch</a>
    </p>

    <h2>Erhobene Daten</h2>
    <p>Wir erheben nur jene Daten, die für den Betrieb dieser Website und die Organisation des Kongresses notwendig sind:</p>
    <ul>
      <li><strong>Anmeldeformular:</strong> Name, E-Mail-Adresse, Ticketkategorie sowie optionale Angaben (Unterstützungsbedarf, Newsletter).</li>
      <li><strong>Kontaktformular:</strong> Name, E-Mail-Adresse, Nachricht.</li>
      <li><strong>Server-Logs:</strong> IP-Adresse, Datum/Uhrzeit, aufgerufene Seite — automatisch durch den Webserver, für max. 30 Tage.</li>
    </ul>

    <h2>Zweck der Bearbeitung</h2>
    <p>Die Daten werden ausschliesslich zur Durchführung des Tierrechtskongresses sowie zur Beantwortung von Anfragen verwendet. Eine Weitergabe an Dritte erfolgt nicht, ausser sie ist zur Veranstaltungsorganisation zwingend erforderlich.</p>

    <h2>Rechtsgrundlage</h2>
    <p>Die Bearbeitung erfolgt gestützt auf das Schweizer Datenschutzgesetz (DSG) sowie — soweit anwendbar — auf Art. 6 Abs. 1 lit. b und a DSGVO (Vertragserfüllung bzw. Einwilligung).</p>

    <h2>Speicherdauer</h2>
    <p>Daten werden gelöscht, sobald sie nicht mehr benötigt werden und keine gesetzlichen Aufbewahrungspflichten entgegenstehen.</p>

    <h2>Deine Rechte</h2>
    <p>Du hast das Recht auf Auskunft, Berichtigung und Löschung deiner Daten. Anfragen richtest du an <a href="mailto:info@tierimfokus.ch">info@tierimfokus.ch</a>.</p>

    <h2>Cookies & Tracking</h2>
    <p>Diese Website setzt keine Tracking-Cookies und verwendet kein Web-Analytics.</p>

    <p><small>Stand: Juni 2026</small></p>
  </div>
</PageLayout>
