---
/**
 * PageLayout — Standard-Seiten-Layout mit Breadcrumbs und optionalem Hero
 */
import type { Locale } from "../lib/i18n";
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalUrl: string;
  alternates?: Partial<Record<Locale, string>>;
  breadcrumbs?: BreadcrumbItem[];
  ogImage?: string;
  noindex?: boolean;
  /** Wenn true: volle Breite ohne Container-Wrap */
  fullWidth?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  locale,
  canonicalUrl,
  alternates,
  breadcrumbs,
  ogImage,
  noindex,
  fullWidth = false,
  jsonLd,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalUrl={canonicalUrl}
  alternates={alternates}
  ogImage={ogImage}
  noindex={noindex}
  jsonLd={jsonLd}
>
{fullWidth ? (
    <slot />
  ) : (
    <div class="container">
      <slot />
    </div>
  )}
</BaseLayout>
